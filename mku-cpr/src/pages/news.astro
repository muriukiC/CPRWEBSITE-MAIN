---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="News — MKU Centre for Placenta Research"
  description="Latest news, updates, and announcements from the MKU Centre for Placenta Research."
  audience="scientific"
>
  <!-- Hero Section -->
  <section class="relative py-20 bg-gradient-to-br from-accent-primary to-accent-secondary overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-[url('https://picsum.photos/seed/news-media-press-research-announcements-journalism/1920/1080.jpg')] bg-cover bg-center opacity-20"></div>
      <div class="absolute inset-0 bg-black/40"></div>
    </div>
    
    <div class="container-prose relative z-10 text-white">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center px-6 py-3 bg-white/20 backdrop-blur-md text-white text-sm font-semibold rounded-full mb-8 border border-white/30">
          📰 Latest News
        </div>
        <h1 class="text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Breaking 
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-accent-secondary">
            Research News
          </span>
        </h1>
        <p class="text-xl lg:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed">
          Stay updated with our latest research breakthroughs, funding announcements, 
          and center developments that are transforming maternal health across Africa.
        </p>
      </div>
    </div>
  </section>

  <!-- Featured News -->
  <section class="py-20 bg-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Featured Story</h2>
        <p class="text-xl text-ink-600">Our biggest breakthrough this month</p>
      </div>

      <article class="group relative bg-gradient-to-br from-accent-primary/5 to-accent-secondary/5 rounded-3xl p-8 border border-accent-primary/20 hover:shadow-2xl transition-all duration-300">
        <div class="flex flex-col lg:flex-row gap-8">
          <div class="lg:w-1/3">
            <div class="w-full h-64 bg-gradient-to-br from-accent-primary/20 to-accent-secondary/20 rounded-2xl overflow-hidden">
              <div class="w-full h-full bg-[url('https://picsum.photos/seed/nature-medicine-journal-publication-research-breakthrough/600/400.jpg')] bg-cover bg-center"></div>
            </div>
            <div class="mt-4 flex items-center gap-3">
              <span class="inline-flex items-center px-3 py-1 bg-accent-primary text-white text-sm font-semibold rounded-full">
                ⭐ Featured
              </span>
              <time class="text-sm text-ink-500">October 15, 2024</time>
            </div>
          </div>
          
          <div class="lg:w-2/3">
            <h3 class="text-3xl font-bold text-ink-900 mb-4">
              Major Breakthrough in Placental Malaria Research Published in Nature Medicine
            </h3>
            <p class="text-lg text-ink-700 leading-relaxed mb-6">
              Our team's groundbreaking study on the single-cell atlas of malaria-infected placenta has been published 
              in Nature Medicine, marking a significant milestone in understanding placental malaria pathology. 
              This research opens new avenues for therapeutic interventions and could save thousands of maternal 
              and infant lives across Africa.
            </p>
            <div class="flex flex-wrap gap-2 mb-6">
              <span class="px-3 py-1 bg-accent-primary/10 text-accent-primary text-sm font-medium rounded-full">Nature Medicine</span>
              <span class="px-3 py-1 bg-accent-secondary/10 text-accent-secondary text-sm font-medium rounded-full">Placental Malaria</span>
              <span class="px-3 py-1 bg-accent-tertiary/10 text-accent-tertiary text-sm font-medium rounded-full">Single Cell Atlas</span>
            </div>
            <button class="px-6 py-3 bg-gradient-to-r from-accent-primary to-accent-secondary text-white font-bold rounded-xl hover:from-accent-secondary hover:to-accent-tertiary transition-all duration-300 transform hover:scale-105 shadow-lg">
              Read Full Story →
            </button>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- Recent News -->
  <section class="py-20 bg-gradient-to-b from-ink-50 to-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Recent Updates</h2>
        <p class="text-xl text-ink-600">More news from our research center</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- News Card 1 -->
        <article class="group relative bg-gradient-to-br from-accent-secondary/5 to-accent-tertiary/5 rounded-2xl p-6 border border-accent-secondary/20 hover:shadow-xl transition-all duration-300">
          <div class="w-full h-48 bg-gradient-to-br from-accent-secondary/20 to-accent-tertiary/20 rounded-xl overflow-hidden mb-4">
            <div class="w-full h-full bg-[url('https://picsum.photos/seed/research-funding-grant-announcement-ceremony/400/300.jpg')] bg-cover bg-center"></div>
          </div>
          <div class="flex items-center gap-2 mb-3">
            <span class="inline-flex items-center px-2 py-1 bg-accent-secondary text-white text-xs font-semibold rounded-full">
              💰 Funding
            </span>
            <time class="text-xs text-ink-500">October 10, 2024</time>
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-3">
            $2.5M Grant Secured for Maternal Health Research
          </h3>
          <p class="text-ink-600 leading-relaxed mb-4">
            The Center has been awarded a major grant from the Gates Foundation to advance our research 
            on maternal health interventions in sub-Saharan Africa.
          </p>
          <button class="w-full px-4 py-2 bg-accent-secondary text-white font-semibold rounded-lg hover:bg-accent-tertiary transition-colors duration-200">
            Learn More →
          </button>
        </article>

        <!-- News Card 2 -->
        <article class="group relative bg-gradient-to-br from-accent-tertiary/5 to-accent-quat/5 rounded-2xl p-6 border border-accent-tertiary/20 hover:shadow-xl transition-all duration-300">
          <div class="w-full h-48 bg-gradient-to-br from-accent-tertiary/20 to-accent-quat/20 rounded-xl overflow-hidden mb-4">
            <div class="w-full h-full bg-[url('https://picsum.photos/seed/international-conference-research-presentation-scientists/400/300.jpg')] bg-cover bg-center"></div>
          </div>
          <div class="flex items-center gap-2 mb-3">
            <span class="inline-flex items-center px-2 py-1 bg-accent-tertiary text-white text-xs font-semibold rounded-full">
              🌍 Conference
            </span>
            <time class="text-xs text-ink-500">October 5, 2024</time>
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-3">
            Research Presented at International Malaria Conference
          </h3>
          <p class="text-ink-600 leading-relaxed mb-4">
            Our team's latest findings on diagnostic innovations were presented at the International 
            Conference on Malaria in Geneva, receiving global recognition.
          </p>
          <button class="w-full px-4 py-2 bg-accent-tertiary text-white font-semibold rounded-lg hover:bg-accent-quat transition-colors duration-200">
            Read More →
          </button>
        </article>

        <!-- News Card 3 -->
        <article class="group relative bg-gradient-to-br from-accent-quat/5 to-accent-violet/5 rounded-2xl p-6 border border-accent-quat/20 hover:shadow-xl transition-all duration-300">
          <div class="w-full h-48 bg-gradient-to-br from-accent-quat/20 to-accent-violet/20 rounded-xl overflow-hidden mb-4">
            <div class="w-full h-full bg-[url('https://picsum.photos/seed/partnership-collaboration-handshake-research-institutions/400/300.jpg')] bg-cover bg-center"></div>
          </div>
          <div class="flex items-center gap-2 mb-3">
            <span class="inline-flex items-center px-2 py-1 bg-accent-quat text-white text-xs font-semibold rounded-full">
              🤝 Partnership
            </span>
            <time class="text-xs text-ink-500">September 28, 2024</time>
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-3">
            New Partnership with Harvard T.H. Chan School
          </h3>
          <p class="text-ink-600 leading-relaxed mb-4">
            We've established a strategic partnership with Harvard's School of Public Health to collaborate 
            on cutting-edge maternal health research projects.
          </p>
          <button class="w-full px-4 py-2 bg-accent-quat text-white font-semibold rounded-lg hover:bg-accent-violet transition-colors duration-200">
            Discover →
          </button>
        </article>

        <!-- News Card 4 -->
        <article class="group relative bg-gradient-to-br from-accent-violet/5 to-accent-coral/5 rounded-2xl p-6 border border-accent-violet/20 hover:shadow-xl transition-all duration-300">
          <div class="w-full h-48 bg-gradient-to-br from-accent-violet/20 to-accent-coral/20 rounded-xl overflow-hidden mb-4">
            <div class="w-full h-full bg-[url('https://picsum.photos/seed/award-ceremony-research-excellence-scientific-achievement/400/300.jpg')] bg-cover bg-center"></div>
          </div>
          <div class="flex items-center gap-2 mb-3">
            <span class="inline-flex items-center px-2 py-1 bg-accent-violet text-white text-xs font-semibold rounded-full">
              🏆 Award
            </span>
            <time class="text-xs text-ink-500">September 20, 2024</time>
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-3">
            Prof. Gitaka Receives Excellence in Research Award
          </h3>
          <p class="text-ink-600 leading-relaxed mb-4">
            Our Director has been recognized with the prestigious African Research Excellence Award 
            for outstanding contributions to maternal health research.
          </p>
          <button class="w-full px-4 py-2 bg-accent-violet text-white font-semibold rounded-lg hover:bg-accent-coral transition-colors duration-200">
            Celebrate →
          </button>
        </article>

        <!-- News Card 5 -->
        <article class="group relative bg-gradient-to-br from-accent-coral/5 to-accent-teal/5 rounded-2xl p-6 border border-accent-coral/20 hover:shadow-xl transition-all duration-300">
          <div class="w-full h-48 bg-gradient-to-br from-accent-coral/20 to-accent-teal/20 rounded-xl overflow-hidden mb-4">
            <div class="w-full h-full bg-[url('https://picsum.photos/seed/laboratory-equipment-new-technology-research-facility/400/300.jpg')] bg-cover bg-center"></div>
          </div>
          <div class="flex items-center gap-2 mb-3">
            <span class="inline-flex items-center px-2 py-1 bg-accent-coral text-white text-xs font-semibold rounded-full">
              🔬 Facility
            </span>
            <time class="text-xs text-ink-500">September 15, 2024</time>
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-3">
            State-of-the-Art Laboratory Now Operational
          </h3>
          <p class="text-ink-600 leading-relaxed mb-4">
            Our new advanced research facility is now fully operational, featuring cutting-edge equipment 
            for genomic analysis and diagnostic development.
          </p>
          <button class="w-full px-4 py-2 bg-accent-coral text-white font-semibold rounded-lg hover:bg-accent-teal transition-colors duration-200">
            Tour Facility →
          </button>
        </article>

        <!-- News Card 6 -->
        <article class="group relative bg-gradient-to-br from-accent-teal/5 to-accent-gold/5 rounded-2xl p-6 border border-accent-teal/20 hover:shadow-xl transition-all duration-300">
          <div class="w-full h-48 bg-gradient-to-br from-accent-teal/20 to-accent-gold/20 rounded-xl overflow-hidden mb-4">
            <div class="w-full h-full bg-[url('https://picsum.photos/seed/students-training-research-education-workshop/400/300.jpg')] bg-cover bg-center"></div>
          </div>
          <div class="flex items-center gap-2 mb-3">
            <span class="inline-flex items-center px-2 py-1 bg-accent-teal text-white text-xs font-semibold rounded-full">
              🎓 Education
            </span>
            <time class="text-xs text-ink-500">September 10, 2024</time>
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-3">
            New Training Program for Young Researchers Launched
          </h3>
          <p class="text-ink-600 leading-relaxed mb-4">
            We've launched a comprehensive training program to mentor the next generation of 
            maternal health researchers across Africa.
          </p>
          <button class="w-full px-4 py-2 bg-accent-teal text-white font-semibold rounded-lg hover:bg-accent-gold transition-colors duration-200">
            Join Program →
          </button>
        </article>
      </div>
    </div>
  </section>

  <!-- Newsletter Signup -->
  <section class="py-20 bg-gradient-to-r from-accent-primary to-accent-secondary relative overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-[url('https://picsum.photos/seed/newsletter-email-subscription-communication/1920/1080.jpg')] bg-cover bg-center opacity-10"></div>
      <div class="absolute top-0 right-0 w-96 h-96 bg-white/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-white/10 rounded-full blur-3xl"></div>
    </div>
    
    <div class="container-prose relative z-10 text-center text-white">
      <div class="inline-flex items-center px-6 py-3 bg-white/20 backdrop-blur-md text-ink-900 text-sm font-semibold rounded-full mb-8 border border-white/30">
        📧 Newsletter Signup
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6 text-ink-900">Stay Connected</h2>
      <p class="text-lg sm:text-xl lg:text-2xl mb-8 max-w-4xl mx-auto leading-relaxed text-yellow-400 font-bold">
        Get the latest news and updates delivered directly to your inbox. 
        Join our community of researchers, healthcare professionals, and supporters.
      </p>
      
      <!-- Enhanced Email Form -->
      <div class="max-w-2xl mx-auto mb-8">
        <div class="bg-black/20 rounded-2xl p-4 sm:p-6 lg:p-8 border border-white/10">
          <div class="flex flex-col lg:flex-row gap-4 items-center">
            <div class="flex-1 w-full lg:w-auto">
              <label class="block text-left text-sm font-medium text-ink-900 mb-2">Email Address</label>
              <input 
                type="email" 
                placeholder="Enter your email address" 
                class="w-full px-4 py-3 sm:px-6 sm:py-4 bg-white/90 backdrop-blur-sm text-ink-900 placeholder-ink-400 rounded-xl focus:outline-none focus:ring-4 focus:ring-white/50 focus:bg-white transition-all duration-300 text-base sm:text-lg font-medium"
              >
            </div>
            <div class="w-full lg:w-auto">
              <label class="block text-left text-sm font-medium text-ink-900 mb-2 lg:invisible">Action</label>
              <button class="w-full lg:w-auto px-6 py-3 sm:px-8 sm:py-4 bg-gradient-to-r from-accent-primary to-accent-secondary text-white font-bold rounded-xl hover:from-accent-secondary hover:to-accent-tertiary transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl text-base sm:text-lg font-bold">
                🚀 Subscribe Now
              </button>
            </div>
          </div>
          <div class="mt-4 flex flex-wrap items-center justify-center gap-4 text-sm text-ink-800">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></div>
              <span>2,000+ subscribers</span>
            </div>
            <span>•</span>
            <span>Weekly updates</span>
            <span>•</span>
            <span>Unsubscribe anytime</span>
          </div>
        </div>
      </div>
      
      <!-- Social Proof -->
      <div class="flex flex-wrap justify-center gap-6 text-white/90">
        <div class="flex items-center gap-2">
          <span class="text-2xl">🏆</span>
          <span class="font-medium">Award-winning research</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-2xl">🌍</span>
          <span class="font-medium">Global impact</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-2xl">📊</span>
          <span class="font-medium">Latest breakthroughs</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Archive Section -->
  <section class="py-20 bg-gradient-to-b from-white to-ink-50">
    <div class="container-prose">
      <div class="text-center mb-16">
        <div class="inline-flex items-center px-6 py-3 bg-accent-primary/10 text-accent-primary text-sm font-semibold rounded-full mb-6 border border-accent-primary/20">
          📚 News Archive
        </div>
        <h2 class="text-4xl lg:text-5xl font-bold text-ink-900 mb-6">News Archive</h2>
        <p class="text-xl lg:text-2xl text-ink-600 max-w-3xl mx-auto">
          Explore our past announcements and milestones from previous years
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- 2024 -->
        <div class="group relative">
          <div class="absolute inset-0 bg-gradient-to-br from-accent-primary/20 to-accent-secondary/20 rounded-3xl transform scale-95 group-hover:scale-100 transition-transform duration-300"></div>
          <div class="relative text-center p-8 bg-white rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-accent-primary/20">
            <div class="w-24 h-24 bg-gradient-to-br from-accent-primary to-accent-secondary rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-6 group-hover:scale-110 group-hover:rotate-3 transition-all duration-300 shadow-lg">
              2024
            </div>
            <h3 class="text-2xl font-bold text-ink-900 mb-3">2024</h3>
            <div class="space-y-2 mb-6">
              <p class="text-lg font-semibold text-accent-primary">24 Articles</p>
              <p class="text-sm text-ink-600">Major breakthroughs</p>
            </div>
            <button class="w-full px-6 py-3 bg-gradient-to-r from-accent-primary to-accent-secondary text-white font-bold rounded-xl hover:from-accent-secondary hover:to-accent-tertiary transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl">
              📖 View 2024 →
            </button>
          </div>
        </div>

        <!-- 2023 -->
        <div class="group relative">
          <div class="absolute inset-0 bg-gradient-to-br from-accent-secondary/20 to-accent-tertiary/20 rounded-3xl transform scale-95 group-hover:scale-100 transition-transform duration-300"></div>
          <div class="relative text-center p-8 bg-white rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-accent-secondary/20">
            <div class="w-24 h-24 bg-gradient-to-br from-accent-secondary to-accent-tertiary rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-6 group-hover:scale-110 group-hover:rotate-3 transition-all duration-300 shadow-lg">
              2023
            </div>
            <h3 class="text-2xl font-bold text-ink-900 mb-3">2023</h3>
            <div class="space-y-2 mb-6">
              <p class="text-lg font-semibold text-accent-secondary">18 Articles</p>
              <p class="text-sm text-ink-600">Research expansion</p>
            </div>
            <button class="w-full px-6 py-3 bg-gradient-to-r from-accent-secondary to-accent-tertiary text-white font-bold rounded-xl hover:from-accent-tertiary hover:to-accent-quat transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl">
              📖 View 2023 →
            </button>
          </div>
        </div>

        <!-- 2022 -->
        <div class="group relative">
          <div class="absolute inset-0 bg-gradient-to-br from-accent-tertiary/20 to-accent-quat/20 rounded-3xl transform scale-95 group-hover:scale-100 transition-transform duration-300"></div>
          <div class="relative text-center p-8 bg-white rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-accent-tertiary/20">
            <div class="w-24 h-24 bg-gradient-to-br from-accent-tertiary to-accent-quat rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-6 group-hover:scale-110 group-hover:rotate-3 transition-all duration-300 shadow-lg">
              2022
            </div>
            <h3 class="text-2xl font-bold text-ink-900 mb-3">2022</h3>
            <div class="space-y-2 mb-6">
              <p class="text-lg font-semibold text-accent-tertiary">15 Articles</p>
              <p class="text-sm text-ink-600">Partnerships formed</p>
            </div>
            <button class="w-full px-6 py-3 bg-gradient-to-r from-accent-tertiary to-accent-quat text-white font-bold rounded-xl hover:from-accent-quat hover:to-accent-violet transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl">
              📖 View 2022 →
            </button>
          </div>
        </div>

        <!-- 2021 -->
        <div class="group relative">
          <div class="absolute inset-0 bg-gradient-to-br from-accent-quat/20 to-accent-violet/20 rounded-3xl transform scale-95 group-hover:scale-100 transition-transform duration-300"></div>
          <div class="relative text-center p-8 bg-white rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-accent-quat/20">
            <div class="w-24 h-24 bg-gradient-to-br from-accent-quat to-accent-violet rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-6 group-hover:scale-110 group-hover:rotate-3 transition-all duration-300 shadow-lg">
              2021
            </div>
            <h3 class="text-2xl font-bold text-ink-900 mb-3">2021</h3>
            <div class="space-y-2 mb-6">
              <p class="text-lg font-semibold text-accent-quat">12 Articles</p>
              <p class="text-sm text-ink-600">Foundation year</p>
            </div>
            <button class="w-full px-6 py-3 bg-gradient-to-r from-accent-quat to-accent-violet text-white font-bold rounded-xl hover:from-accent-violet hover:to-accent-coral transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl">
              📖 View 2021 →
            </button>
          </div>
        </div>
      </div>

      <!-- Additional Archive Info -->
      <div class="mt-16 text-center">
        <div class="inline-flex items-center px-6 py-3 bg-ink-100 rounded-full">
          <span class="text-ink-600 font-medium">Total: </span>
          <span class="text-2xl font-bold text-accent-primary mx-2">69</span>
          <span class="text-ink-600 font-medium">articles published</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
