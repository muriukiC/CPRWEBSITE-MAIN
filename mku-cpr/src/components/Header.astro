---
// Enhanced Header with improved styling and active states
// Uses Astro.url.pathname to derive the active tab with better logic

const { pathname } = Astro.url;
const base = import.meta.env.BASE_URL;

const navItems = [
  { href: `${base}`, label: "Home", icon: "🏠" },
  { href: `${base}research/`, label: "Research", icon: "🔬" },
  { href: `${base}people/`, label: "People", icon: "👥" },
  { href: `${base}publications/`, label: "Publications", icon: "📚" },
  { href: `${base}news/`, label: "News", icon: "📰" },
  { href: `${base}community/`, label: "Community", icon: "🤝" },
  { href: `${base}about/`, label: "About", icon: "ℹ️" },
  { href: `${base}contact/`, label: "Contact", icon: "📧" },
];

function isActive(href: string) {
  // More precise active state logic with trailing slash normalization
  const cleanPathname = pathname.replace(/\/+$/, "") || "/";
  const cleanHref = href.replace(/\/+$/, "") || "/";
  
  if (cleanHref === "/") {
    return cleanPathname === "/";
  }
  
  return cleanPathname === cleanHref || cleanPathname.startsWith(cleanHref + "/");
}
---

<header class="sticky top-0 z-[1000] bg-white border-b border-ink-100 shadow-sm backdrop-blur-lg" role="banner">
  <div class="container-prose flex items-center justify-between py-sp-4">
    <!-- Professional Logo -->
    <a href={base} class="group flex items-center gap-sp-3 no-underline" aria-label="MKU Centre for Placenta Research — home">
      <div class="relative">
        <div class="w-14 h-14 bg-gradient-to-br from-accent-primary to-accent-secondary rounded-xl flex items-center justify-center text-white font-display text-step-2 font-bold shadow-lg transition-all duration-300 group-hover:scale-105 group-hover:shadow-xl">
          CP
        </div>
        <div class="absolute -bottom-1 -right-1 w-4 h-4 bg-accent-tertiary rounded-full border-2 border-white"></div>
      </div>
      <div class="text-left">
        <span class="font-display text-step-1 text-ink-900 font-bold block">MKU CPR</span>
        <span class="text-step--2 text-ink-500 font-medium hidden sm:block">Centre for Placenta Research</span>
      </div>
    </a>
    
    <!-- Desktop Navigation -->
    <nav aria-label="Primary" class="hidden lg:block">
      <ul class="flex items-center gap-1 list-none p-0 m-0">
        {navItems.map((item, index) => (
          <li>
            <a 
              href={item.href} 
              class={`group relative px-3 py-2 rounded-lg text-sm font-semibold no-underline transition-all duration-300 tap-target flex items-center gap-2
                ${isActive(item.href) 
                  ? [
                      'bg-gradient-to-r from-accent-primary to-accent-secondary',
                      'bg-gradient-to-r from-accent-secondary to-accent-tertiary',
                      'bg-gradient-to-r from-accent-tertiary to-accent-quat',
                      'bg-gradient-to-r from-accent-quat to-accent-violet',
                      'bg-gradient-to-r from-accent-violet to-accent-coral',
                      'bg-gradient-to-r from-accent-coral to-accent-primary'
                    ][index % 6] + ' text-white shadow-lg transform scale-105' 
                  : 'text-ink-600 hover:text-white hover:shadow-lg hover:transform hover:scale-105'
                }`}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              <!-- Background Gradient for Hover -->
              <div class={`absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-lg -z-10
                ${[
                  'bg-gradient-to-r from-accent-primary to-accent-secondary',
                  'bg-gradient-to-r from-accent-secondary to-accent-tertiary',
                  'bg-gradient-to-r from-accent-tertiary to-accent-quat',
                  'bg-gradient-to-r from-accent-quat to-accent-violet',
                  'bg-gradient-to-r from-accent-violet to-accent-coral',
                  'bg-gradient-to-r from-accent-coral to-accent-primary'
                ][index % 6]}`}></div>
              
              <span class="relative z-10 text-sm transition-all duration-300 group-hover:scale-110">
                {item.icon}
              </span>
              <span class="relative z-10">{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
    
    <!-- Professional Actions -->
    <div class="flex items-center gap-3">
      <a href={`${base}contact/`} class="hidden sm:flex items-center px-4 py-2 bg-gradient-to-r from-accent-primary to-accent-secondary text-white text-sm font-semibold no-underline rounded-lg hover:from-accent-secondary hover:to-accent-tertiary transition-all duration-300 transform hover:scale-105 shadow-lg">
        Contact
      </a>
      
      <!-- Mobile Menu Toggle Button -->
      <button 
        id="mobileToggle"
        class="lg:hidden p-2 text-ink-600 hover:text-accent-primary hover:bg-ink-50 rounded-lg transition-all duration-300 relative z-[1002]" 
        aria-label="Toggle navigation menu" 
        aria-expanded="false" 
        aria-controls="mobileMenu"
      >
        <div class="w-6 h-6 flex flex-col justify-center gap-1.5 overflow-hidden">
          <span class="w-full h-0.5 bg-current transition-all duration-300 transform line-top"></span>
          <span class="w-full h-0.5 bg-current transition-all duration-300 transform line-mid"></span>
          <span class="w-full h-0.5 bg-current transition-all duration-300 transform line-bot"></span>
        </div>
      </button>
    </div>
  </div>

  <!-- Mobile Slide-down Menu (Premium Glassmorphism) -->
  <div 
    id="mobileMenu" 
    class="absolute top-full left-0 right-0 bg-white/90 backdrop-blur-xl border-b border-white/20 shadow-2xl z-[999] lg:hidden hidden animate-premium-slide"
    role="navigation" 
    aria-label="Mobile navigation"
  >
    <div class="px-sp-4 py-sp-8 max-h-[85vh] overflow-y-auto overscroll-contain">
      <!-- Section Tag -->
      <div class="px-sp-4 mb-sp-4 flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-accent-primary animate-pulse"></span>
        <span class="text-step--2 uppercase tracking-widest font-bold text-ink-500">Main Menu</span>
      </div>

      <ul class="flex flex-col gap-sp-2 list-none p-0 m-0">
        {navItems.map((item, index) => (
          <li>
            <a 
              href={item.href} 
              class={`group relative flex items-center gap-sp-4 px-sp-5 py-sp-4 rounded-2xl text-step-0 font-bold no-underline transition-all duration-500 overflow-hidden
                ${isActive(item.href) 
                  ? [
                      'bg-gradient-to-r from-accent-primary to-accent-secondary',
                      'bg-gradient-to-r from-accent-secondary to-accent-tertiary',
                      'bg-gradient-to-r from-accent-tertiary to-accent-quat',
                      'bg-gradient-to-r from-accent-quat to-accent-violet',
                      'bg-gradient-to-r from-accent-violet to-accent-coral',
                      'bg-gradient-to-r from-accent-coral to-accent-primary'
                    ][index % 6] + ' text-white shadow-lg scale-[1.02]' 
                  : 'text-ink-700 hover:text-accent-primary hover:bg-white/50 active:scale-95'
                }`}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              <!-- Sparkle Effect for Active/Hover -->
              <div class="absolute inset-0 opacity-0 group-hover:opacity-20 bg-gradient-to-tr from-white/0 via-white/40 to-white/0 -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
              
              <span class="text-step-1 transition-transform duration-500 group-hover:scale-125 group-hover:rotate-12 flex-shrink-0">
                {item.icon}
              </span>
              <span class="flex-1 transition-all duration-300 group-hover:translate-x-1">{item.label}</span>
              
              <div class={`w-8 h-8 rounded-full flex items-center justify-center transition-all duration-500
                ${isActive(item.href) ? 'bg-white/20' : 'bg-ink-50 group-hover:bg-accent-primary/10'}
              `}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class={`transition-transform duration-500 ${isActive(item.href) ? 'translate-x-0' : '-translate-x-1 group-hover:translate-x-0'}`}>
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
              </div>
            </a>
          </li>
        ))}
      </ul>
      
      <div class="mt-8 pt-8 border-t border-ink-100/50">
        <a href={`${base}contact/`} class="group relative w-full flex items-center justify-center gap-3 px-sp-6 py-4 bg-ink-900 text-white font-bold no-underline rounded-2xl hover:bg-accent-primary transition-all duration-500 shadow-xl active:scale-95 overflow-hidden">
          <!-- Button Background Shine -->
          <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:animate-shimmer"></div>
          
          <span class="relative z-10">Get in Touch</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="relative z-10 animate-pulse">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
        </a>
        <p class="text-center mt-6 text-step--2 text-ink-400 font-medium tracking-wide">MKU Centre for Placenta Research</p>
      </div>
    </div>
  </div>

  <style>
    /* Toggle Button Animation */
    .btn-active .line-top {
      transform: translateY(8px) rotate(45deg) scaleX(1.1);
    }
    .btn-active .line-mid {
      opacity: 0;
      transform: translateX(-20px);
    }
    .btn-active .line-bot {
      transform: translateY(-8px) rotate(-45deg) scaleX(1.1);
    }
    
    @keyframes premiumSlide {
      0% {
        opacity: 0;
        transform: translateY(-20px) scale(0.98);
        filter: blur(10px);
      }
      100% {
        opacity: 1;
        transform: translateY(0) scale(1);
        filter: blur(0);
      }
    }

    @keyframes shimmer {
      100% {
        transform: translateX(100%);
      }
    }
    
    .animate-premium-slide {
      animation: premiumSlide 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .animate-shimmer {
      animation: shimmer 2s infinite;
    }

    body.menu-open {
      overflow: hidden;
      height: 100vh; /* Lock height to prevent any scroll behavior */
    }
  </style>

  <script is:inline>
    (function() {
      const toggle = document.getElementById('mobileToggle');
      const menu = document.getElementById('mobileMenu');
      const body = document.body;

      function toggleMenu() {
        const isOpen = !menu.classList.contains('hidden');
        if (isOpen) {
          menu.classList.add('hidden');
          toggle.classList.remove('btn-active');
          toggle.setAttribute('aria-expanded', 'false');
          body.classList.remove('menu-open');
        } else {
          menu.classList.remove('hidden');
          toggle.classList.add('btn-active');
          toggle.setAttribute('aria-expanded', 'true');
          body.classList.add('menu-open');
        }
      }

      toggle?.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleMenu();
      });
      
      // Close on click outside
      document.addEventListener('click', (e) => {
        if (!menu?.classList.contains('hidden') && !menu?.contains(e.target) && !toggle?.contains(e.target)) {
          toggleMenu();
        }
      });
      
      // Close on escape
      window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !menu?.classList.contains('hidden')) {
          toggleMenu();
        }
      });

      // Close on resize
      window.addEventListener('resize', () => {
        if (window.innerWidth >= 1024 && !menu?.classList.contains('hidden')) {
          toggleMenu();
        }
      });
    })();
  </script>
</header>
