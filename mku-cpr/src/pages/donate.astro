---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Donate — MKU Centre for Placenta Research"
  description="Support our mission to transform maternal health outcomes across Africa. Your donation helps fund groundbreaking research and save lives."
  audience="funder"
>
  <!-- Hero Section -->
  <section class="relative py-20 bg-gradient-to-br from-accent-primary to-accent-secondary overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-[url('https://picsum.photos/seed/donate-charity-giving-support-research-funding-maternal-health/1920/1080.jpg')] bg-cover bg-center opacity-20"></div>
      <div class="absolute inset-0 bg-black/40"></div>
    </div>
    
    <div class="container-prose relative z-10 text-white">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center px-6 py-3 bg-white/20 backdrop-blur-md text-white text-sm font-semibold rounded-full mb-8 border border-white/30">
          ❤️ Support Our Mission
        </div>
        <h1 class="text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Transform 
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-accent-secondary">
            Maternal Health
          </span>
        </h1>
        <p class="text-xl lg:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed">
          Your donation supports groundbreaking research that saves mothers' and babies' lives 
          across Africa and around the world.
        </p>
      </div>
    </div>
  </section>

  <!-- Impact Overview -->
  <section class="py-20 bg-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Your Impact</h2>
        <p class="text-xl text-ink-600">See how your donation makes a difference</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-20 h-20 bg-gradient-to-br from-accent-primary to-accent-secondary rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4">
            🤰
          </div>
          <div class="text-3xl font-bold text-accent-primary mb-2">10,000+</div>
          <p class="text-ink-700">Mothers helped through research</p>
        </div>
        
        <div class="text-center">
          <div class="w-20 h-20 bg-gradient-to-br from-accent-secondary to-accent-tertiary rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4">
            👶
          </div>
          <div class="text-3xl font-bold text-accent-secondary mb-2">50,000+</div>
          <p class="text-ink-700">Babies protected from complications</p>
        </div>
        
        <div class="text-center">
          <div class="w-20 h-20 bg-gradient-to-br from-accent-tertiary to-accent-quat rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4">
            🔬
          </div>
          <div class="text-3xl font-bold text-accent-tertiary mb-2">25+</div>
          <p class="text-ink-700">Research breakthroughs achieved</p>
        </div>
        
        <div class="text-center">
          <div class="w-20 h-20 bg-gradient-to-br from-accent-quat to-accent-violet rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4">
            🌍
          </div>
          <div class="text-3xl font-bold text-accent-quat mb-2">15+</div>
          <p class="text-ink-700">African countries impacted</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Donation Options -->
  <section class="py-20 bg-gradient-to-b from-ink-50 to-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Ways to Give</h2>
        <p class="text-xl text-ink-600">Choose the donation option that works for you</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- One-time Donation -->
        <div class="bg-white rounded-3xl shadow-2xl p-8 hover:shadow-3xl transition-all duration-300">
          <div class="w-16 h-16 bg-gradient-to-br from-accent-primary to-accent-secondary rounded-2xl flex items-center justify-center text-white text-2xl font-bold mb-6">
            💳
          </div>
          <h3 class="text-2xl font-bold text-ink-900 mb-4">One-Time Donation</h3>
          <p class="text-ink-700 mb-6">
            Make a single donation to support our current research projects and immediate needs.
          </p>
          <ul class="space-y-2 text-ink-600 mb-6">
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Immediate impact
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Flexible amount
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Tax deductible
            </li>
          </ul>
          <button class="w-full px-6 py-3 bg-gradient-to-r from-accent-primary to-accent-secondary text-white font-bold rounded-xl hover:from-accent-secondary hover:to-accent-tertiary transition-all duration-300 transform hover:scale-105 shadow-lg">
            Donate Now →
          </button>
        </div>

        <!-- Monthly Giving -->
        <div class="bg-white rounded-3xl shadow-2xl p-8 hover:shadow-3xl transition-all duration-300">
          <div class="w-16 h-16 bg-gradient-to-br from-accent-secondary to-accent-tertiary rounded-2xl flex items-center justify-center text-white text-2xl font-bold mb-6">
            🔄
          </div>
          <h3 class="text-2xl font-bold text-ink-900 mb-4">Monthly Giving</h3>
          <p class="text-ink-700 mb-6">
            Provide sustained support with monthly donations that ensure long-term research continuity.
          </p>
          <ul class="space-y-2 text-ink-600 mb-6">
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Sustained impact
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Budget-friendly
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Exclusive updates
            </li>
          </ul>
          <button class="w-full px-6 py-3 bg-gradient-to-r from-accent-secondary to-accent-tertiary text-white font-bold rounded-xl hover:from-accent-tertiary hover:to-accent-quat transition-all duration-300 transform hover:scale-105 shadow-lg">
            Become Monthly Donor →
          </button>
        </div>

        <!-- Research Sponsorship -->
        <div class="bg-white rounded-3xl shadow-2xl p-8 hover:shadow-3xl transition-all duration-300">
          <div class="w-16 h-16 bg-gradient-to-br from-accent-tertiary to-accent-quat rounded-2xl flex items-center justify-center text-white text-2xl font-bold mb-6">
            🎯
          </div>
          <h3 class="text-2xl font-bold text-ink-900 mb-4">Research Sponsorship</h3>
          <p class="text-ink-700 mb-6">
            Sponsor specific research projects or programs that align with your interests and values.
          </p>
          <ul class="space-y-2 text-ink-600 mb-6">
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Targeted impact
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Recognition opportunities
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Direct involvement
            </li>
          </ul>
          <button class="w-full px-6 py-3 bg-gradient-to-r from-accent-tertiary to-accent-quat text-white font-bold rounded-xl hover:from-accent-quat hover:to-accent-violet transition-all duration-300 transform hover:scale-105 shadow-lg">
            Sponsor Research →
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Donation Form -->
  <section class="py-20 bg-white">
    <div class="container-prose">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold text-ink-900 mb-4">Make Your Donation</h2>
          <p class="text-xl text-ink-600">Every contribution makes a difference</p>
        </div>

        <div class="bg-gradient-to-br from-accent-primary/5 to-accent-secondary/5 rounded-3xl p-8 lg:p-12 border border-accent-primary/20">
          <form class="space-y-8">
            <!-- Donation Amount -->
            <div>
              <label class="block text-lg font-bold text-ink-900 mb-4">Select Donation Amount</label>
              <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
                <button type="button" class="py-4 px-6 bg-gradient-to-r from-accent-quat to-accent-violet text-white font-bold rounded-xl hover:from-accent-violet hover:to-accent-coral transition-all duration-300">
                  $25
                </button>
                <button type="button" class="py-4 px-6 bg-gradient-to-r from-accent-quat to-accent-violet text-white font-bold rounded-xl hover:from-accent-violet hover:to-accent-coral transition-all duration-300">
                  $50
                </button>
                <button type="button" class="py-4 px-6 bg-gradient-to-r from-accent-quat to-accent-violet text-white font-bold rounded-xl hover:from-accent-violet hover:to-accent-coral transition-all duration-300">
                  $100
                </button>
                <button type="button" class="py-4 px-6 bg-gradient-to-r from-accent-quat to-accent-violet text-white font-bold rounded-xl hover:from-accent-violet hover:to-accent-coral transition-all duration-300">
                  $250
                </button>
              </div>
              <div class="flex items-center gap-4">
                <input 
                  type="number" 
                  placeholder="Custom amount"
                  class="flex-1 px-4 py-3 border border-ink-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent-primary focus:border-transparent"
                >
                <select class="px-4 py-3 border border-ink-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent-primary focus:border-transparent">
                  <option>One-time</option>
                  <option>Monthly</option>
                </select>
              </div>
            </div>

            <!-- Personal Information -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-bold text-ink-900 mb-2">First Name *</label>
                <input 
                  type="text" 
                  required
                  class="w-full px-4 py-3 border border-ink-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent-primary focus:border-transparent"
                  placeholder="John"
                >
              </div>
              <div>
                <label class="block text-sm font-bold text-ink-900 mb-2">Last Name *</label>
                <input 
                  type="text" 
                  required
                  class="w-full px-4 py-3 border border-ink-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent-primary focus:border-transparent"
                  placeholder="Doe"
                >
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-bold text-ink-900 mb-2">Email Address *</label>
                <input 
                  type="email" 
                  required
                  class="w-full px-4 py-3 border border-ink-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent-primary focus:border-transparent"
                  placeholder="john.doe@example.com"
                >
              </div>
              <div>
                <label class="block text-sm font-bold text-ink-900 mb-2">Phone Number</label>
                <input 
                  type="tel" 
                  class="w-full px-4 py-3 border border-ink-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent-primary focus:border-transparent"
                  placeholder="+254 700 000 000"
                >
              </div>
            </div>

            <!-- Payment Information -->
            <div>
              <label class="block text-sm font-bold text-ink-900 mb-2">Card Number *</label>
              <input 
                type="text" 
                required
                class="w-full px-4 py-3 border border-ink-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent-primary focus:border-transparent"
                placeholder="1234 5678 9012 3456"
              >
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-bold text-ink-900 mb-2">Expiry Date *</label>
                <input 
                  type="text" 
                  required
                  class="w-full px-4 py-3 border border-ink-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent-primary focus:border-transparent"
                  placeholder="MM/YY"
                >
              </div>
              <div>
                <label class="block text-sm font-bold text-ink-900 mb-2">CVV *</label>
                <input 
                  type="text" 
                  required
                  class="w-full px-4 py-3 border border-ink-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent-primary focus:border-transparent"
                  placeholder="123"
                >
              </div>
            </div>

            <!-- Donation Options -->
            <div class="space-y-4">
              <div class="flex items-center gap-3">
                <input 
                  type="checkbox" 
                  id="anonymous"
                  class="w-4 h-4 text-accent-primary border-ink-300 rounded focus:ring-accent-primary"
                >
                <label for="anonymous" class="text-sm text-ink-700">
                  Make this donation anonymous
                </label>
              </div>
              
              <div class="flex items-center gap-3">
                <input 
                  type="checkbox" 
                  id="updates"
                  class="w-4 h-4 text-accent-primary border-ink-300 rounded focus:ring-accent-primary"
                >
                <label for="updates" class="text-sm text-ink-700">
                  Send me updates about the impact of my donation
                </label>
              </div>
            </div>

            <!-- Submit Button -->
            <button 
              type="submit" 
              class="w-full px-8 py-4 bg-gradient-to-r from-accent-primary to-accent-secondary text-white font-bold rounded-xl hover:from-accent-secondary hover:to-accent-tertiary transition-all duration-300 transform hover:scale-105 shadow-lg text-lg"
            >
              Complete Donation →
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Other Ways to Give -->
  <section class="py-20 bg-gradient-to-b from-ink-50 to-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Other Ways to Give</h2>
        <p class="text-xl text-ink-600">Multiple options to support our mission</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-20 h-20 bg-gradient-to-br from-accent-primary to-accent-secondary rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4">
            🏦
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-3">Bank Transfer</h3>
          <p class="text-ink-700 mb-4">
            Transfer directly to our bank account for larger donations.
          </p>
          <button class="text-accent-primary font-semibold hover:text-accent-secondary">
            Get Bank Details →
          </button>
        </div>
        
        <div class="text-center">
          <div class="w-20 h-20 bg-gradient-to-br from-accent-secondary to-accent-tertiary rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4">
            📱
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-3">Mobile Money</h3>
          <p class="text-ink-700 mb-4">
            Donate via M-Pesa, Airtel Money, or other mobile payment platforms.
          </p>
          <button class="text-accent-secondary font-semibold hover:text-accent-tertiary">
            Mobile Payment Info →
          </button>
        </div>
        
        <div class="text-center">
          <div class="w-20 h-20 bg-gradient-to-br from-accent-tertiary to-accent-quat rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4">
            🏢
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-3">Corporate Giving</h3>
          <p class="text-ink-700 mb-4">
            Partner with us through corporate social responsibility programs.
          </p>
          <button class="text-accent-tertiary font-semibold hover:text-accent-quat">
            Corporate Partnerships →
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-20 bg-gradient-to-r from-accent-primary to-accent-secondary">
    <div class="container-prose text-center text-white">
      <h2 class="text-4xl font-bold mb-6">Your Gift Saves Lives</h2>
      <p class="text-xl mb-8 max-w-3xl mx-auto">
        Every donation brings us closer to a world where every mother and baby 
        has the chance to thrive, regardless of where they live.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <button class="px-8 py-4 bg-gradient-to-r from-accent-violet to-accent-coral text-white font-bold rounded-xl hover:from-accent-coral hover:to-accent-primary transition-all duration-300 transform hover:scale-105 shadow-lg">
          Donate Now
        </button>
        <button class="px-8 py-4 bg-transparent border-2 border-accent-tertiary text-accent-tertiary font-bold rounded-xl hover:bg-accent-tertiary hover:text-white transition-all duration-200">
          Learn About Our Impact
        </button>
      </div>
    </div>
  </section>
</BaseLayout>
