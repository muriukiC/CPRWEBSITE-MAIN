---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — MKU Centre for Placenta Research"
  description="Get in touch with Africa's first dedicated placental research centre. Contact us for research collaborations, partnerships, or general inquiries."
  audience="scientific"
>
  <!-- Hero Section -->
  <section class="relative py-20 bg-gradient-to-br from-accent-primary to-accent-secondary overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-[url('https://picsum.photos/seed/contact-research-center-laboratory-communication-professional/1920/1080.jpg')] bg-cover bg-center opacity-20"></div>
      <div class="absolute inset-0 bg-black/40"></div>
    </div>
    
    <div class="container-prose relative z-10 text-white">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center px-6 py-3 bg-white/20 backdrop-blur-md text-ink-900 text-sm font-semibold rounded-full mb-8 border border-white/30">
          📧 Get in Touch
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-6 leading-tight text-white">
          Contact 
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-yellow-400 to-orange-500">
            Our Team
          </span>
        </h1>
        <p class="text-lg sm:text-xl lg:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed">
          We welcome collaborations, partnerships, and inquiries from researchers, 
          healthcare professionals, and organizations passionate about improving maternal health.
        </p>
      </div>
    </div>
  </section>

  <!-- Health Logo Section -->
  <section class="py-16 bg-gradient-to-r from-accent-primary/10 to-accent-secondary/10">
    <div class="container-prose">
      <div class="text-center">
        <!-- Health Logo -->
        <div class="inline-flex items-center justify-center w-24 h-24 sm:w-28 sm:h-28 lg:w-32 lg:h-32 bg-gradient-to-br from-red-500 to-pink-600 rounded-full shadow-2xl mb-8 relative overflow-hidden">
          <!-- Medical Cross Symbol -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="relative scale-75 sm:scale-90 lg:scale-100">
              <!-- Cross Background -->
              <div class="w-16 h-16 bg-white rounded-lg"></div>
              <!-- Horizontal Bar -->
              <div class="absolute top-1/2 left-1/2 w-12 h-3 bg-red-500 transform -translate-x-1/2 -translate-y-1/2 rounded-sm"></div>
              <!-- Vertical Bar -->
              <div class="absolute top-1/2 left-1/2 w-3 h-12 bg-red-500 transform -translate-x-1/2 -translate-y-1/2 rounded-sm"></div>
            </div>
          </div>
          <!-- Pulse Animation -->
          <div class="absolute inset-0 bg-red-400 rounded-full animate-ping opacity-20"></div>
        </div>
        
        <h2 class="text-4xl font-bold text-ink-900 mb-4">MKU Centre for Placenta Research</h2>
        <p class="text-xl text-ink-600 max-w-3xl mx-auto">
          Advancing maternal and newborn health through groundbreaking placental research 
          and innovative healthcare solutions for Africa and beyond.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Information -->
  <section class="py-20 bg-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Get in Touch</h2>
        <p class="text-xl text-ink-600">Multiple ways to reach our team</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Main Office -->
        <div class="bg-gradient-to-br from-accent-primary/5 to-accent-secondary/5 rounded-3xl p-8 border border-accent-primary/20 hover:shadow-2xl transition-all duration-300">
          <div class="w-16 h-16 bg-gradient-to-br from-accent-primary to-accent-secondary rounded-2xl flex items-center justify-center text-white text-2xl font-bold mb-6">
            📍
          </div>
          <h3 class="text-2xl font-bold text-ink-900 mb-4">Main Office</h3>
          <div class="space-y-3 text-ink-700">
            <p class="flex items-start gap-3">
              <span class="text-accent-primary font-semibold">Address:</span>
              <span>MKU Centre for Placenta Research<br>Mount Kenya University<br>Thika Road, Nairobi, Kenya</span>
            </p>
            <p class="flex items-center gap-3">
              <span class="text-accent-primary font-semibold">Phone:</span>
              <span>+254 700 123 456</span>
            </p>
            <p class="flex items-center gap-3">
              <span class="text-accent-primary font-semibold">Email:</span>
              <span>info@mku-cpr.org</span>
            </p>
          </div>
        </div>

        <!-- Research Inquiries -->
        <div class="bg-gradient-to-br from-accent-secondary/5 to-accent-tertiary/5 rounded-3xl p-8 border border-accent-secondary/20 hover:shadow-2xl transition-all duration-300">
          <div class="w-16 h-16 bg-gradient-to-br from-accent-secondary to-accent-tertiary rounded-2xl flex items-center justify-center text-white text-2xl font-bold mb-6">
            🔬
          </div>
          <h3 class="text-2xl font-bold text-ink-900 mb-4">Research Inquiries</h3>
          <div class="space-y-3 text-ink-700">
            <p class="flex items-start gap-3">
              <span class="text-accent-secondary font-semibold">Director:</span>
              <span>Prof. Jesse Gitaka<br>director@mku-cpr.org</span>
            </p>
            <p class="flex items-center gap-3">
              <span class="text-accent-secondary font-semibold">Research:</span>
              <span>research@mku-cpr.org</span>
            </p>
            <p class="flex items-center gap-3">
              <span class="text-accent-secondary font-semibold">Lab:</span>
              <span>+254 700 123 457</span>
            </p>
          </div>
        </div>

        <!-- Partnerships -->
        <div class="bg-gradient-to-br from-accent-tertiary/5 to-accent-quat/5 rounded-3xl p-8 border border-accent-tertiary/20 hover:shadow-2xl transition-all duration-300">
          <div class="w-16 h-16 bg-gradient-to-br from-accent-tertiary to-accent-quat rounded-2xl flex items-center justify-center text-white text-2xl font-bold mb-6">
            🤝
          </div>
          <h3 class="text-2xl font-bold text-ink-900 mb-4">Partnerships</h3>
          <div class="space-y-3 text-ink-700">
            <p class="flex items-start gap-3">
              <span class="text-accent-tertiary font-semibold">Partnerships:</span>
              <span>partners@mku-cpr.org</span>
            </p>
            <p class="flex items-center gap-3">
              <span class="text-accent-tertiary font-semibold">Funding:</span>
              <span>funding@mku-cpr.org</span>
            </p>
            <p class="flex items-center gap-3">
              <span class="text-accent-tertiary font-semibold">Media:</span>
              <span>media@mku-cpr.org</span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="py-20 bg-gradient-to-b from-ink-50 to-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Send Us a Message</h2>
        <p class="text-xl text-ink-600">We'll get back to you within 48 hours</p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-3xl shadow-2xl p-8 lg:p-12">
          <form class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-bold text-ink-900 mb-2">First Name *</label>
                <input 
                  type="text" 
                  required
                  class="w-full px-4 py-3 border border-ink-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent-primary focus:border-transparent"
                  placeholder="John"
                >
              </div>
              <div>
                <label class="block text-sm font-bold text-ink-900 mb-2">Last Name *</label>
                <input 
                  type="text" 
                  required
                  class="w-full px-4 py-3 border border-ink-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent-primary focus:border-transparent"
                  placeholder="Doe"
                >
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-bold text-ink-900 mb-2">Email Address *</label>
                <input 
                  type="email" 
                  required
                  class="w-full px-4 py-3 border border-ink-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent-primary focus:border-transparent"
                  placeholder="john.doe@example.com"
                >
              </div>
              <div>
                <label class="block text-sm font-bold text-ink-900 mb-2">Phone Number</label>
                <input 
                  type="tel" 
                  class="w-full px-4 py-3 border border-ink-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent-primary focus:border-transparent"
                  placeholder="+254 700 000 000"
                >
              </div>
            </div>

            <div>
              <label class="block text-sm font-bold text-ink-900 mb-2">Organization/Institution</label>
              <input 
                type="text" 
                class="w-full px-4 py-3 border border-ink-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent-primary focus:border-transparent"
                placeholder="Mount Kenya University"
              >
            </div>

            <div>
              <label class="block text-sm font-bold text-ink-900 mb-2">Subject *</label>
              <select 
                required
                class="w-full px-4 py-3 border border-ink-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent-primary focus:border-transparent"
              >
                <option value="">Select a subject</option>
                <option value="research">Research Collaboration</option>
                <option value="partnership">Partnership Opportunity</option>
                <option value="media">Media Inquiry</option>
                <option value="funding">Funding Opportunity</option>
                <option value="career">Career Opportunity</option>
                <option value="general">General Inquiry</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-bold text-ink-900 mb-2">Message *</label>
              <textarea 
                required
                rows="6"
                class="w-full px-4 py-3 border border-ink-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent-primary focus:border-transparent resize-none"
                placeholder="Tell us more about your inquiry..."
              ></textarea>
            </div>

            <div class="flex items-center gap-3">
              <input 
                type="checkbox" 
                id="newsletter"
                class="w-4 h-4 text-accent-primary border-ink-300 rounded focus:ring-accent-primary"
              >
              <label for="newsletter" class="text-sm text-ink-700">
                I'd like to receive updates about MKU CPR research and news
              </label>
            </div>

            <div class="flex flex-col sm:flex-row gap-4">
              <button 
                type="submit" 
                class="flex-1 px-8 py-4 bg-gradient-to-r from-accent-primary to-accent-secondary text-white font-bold rounded-xl hover:from-accent-secondary hover:to-accent-tertiary transition-all duration-300 transform hover:scale-105 shadow-lg"
              >
                Send Message →
              </button>
              <button 
                type="reset" 
                class="px-8 py-4 bg-ink-100 text-ink-700 font-bold rounded-xl hover:bg-ink-200 transition-colors duration-200"
              >
                Clear Form
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Office Hours -->
  <section class="py-20 bg-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Office Hours</h2>
        <p class="text-xl text-ink-600">When you can reach us</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-20 h-20 bg-gradient-to-br from-accent-primary to-accent-secondary rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4">
            🏢
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-3">Main Office</h3>
          <div class="text-ink-700 space-y-2">
            <p>Monday - Friday: 8:00 AM - 6:00 PM</p>
            <p>Saturday: 9:00 AM - 1:00 PM</p>
            <p>Sunday: Closed</p>
          </div>
        </div>
        
        <div class="text-center">
          <div class="w-20 h-20 bg-gradient-to-br from-accent-secondary to-accent-tertiary rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4">
            🔬
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-3">Laboratory</h3>
          <div class="text-ink-700 space-y-2">
            <p>Monday - Friday: 7:00 AM - 8:00 PM</p>
            <p>Saturday: 8:00 AM - 4:00 PM</p>
            <p>Sunday: 10:00 AM - 2:00 PM</p>
          </div>
        </div>
        
        <div class="text-center">
          <div class="w-20 h-20 bg-gradient-to-br from-accent-tertiary to-accent-quat rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4">
            📧
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-3">Email Response</h3>
          <div class="text-ink-700 space-y-2">
            <p>Weekdays: Within 24 hours</p>
            <p>Weekends: Within 48 hours</p>
            <p>Urgent: Call main office</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Emergency Contact -->
  <section class="py-20 bg-gradient-to-b from-ink-50 to-white">
    <div class="container-prose">
      <div class="bg-gradient-to-r from-red-500 to-orange-500 rounded-3xl p-8 text-white text-center">
        <div class="w-20 h-20 bg-white/20 rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4">
          🚨
        </div>
        <h2 class="text-3xl font-bold mb-4">Emergency Contact</h2>
        <p class="text-xl mb-6 max-w-2xl mx-auto">
          For urgent research matters or emergencies, please contact our 24/7 hotline
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <div class="text-2xl font-bold">+254 700 123 999</div>
          <div class="text-white/80">Available 24/7 for urgent matters</div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
      </div>
    </div>
  </section>
</BaseLayout>
