{
  "name": "mku-cpr",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Mount Kenya University — Centre for Placenta Research (public website)",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist --output-subdir _pagefind",
    "build:astro": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "lint": "eslint . --ext .js,.cjs,.mjs,.ts,.tsx,.astro && prettier --check .",
    "format": "prettier --write .",
    "test:a11y": "axe http://localhost:4321 --exit",
    "test:perf": "lhci autorun",
    "check:dois": "node scripts/check-dois.mjs",
    "check:editorial": "node scripts/check-editorial.mjs",
    "deploy": "astro build && gh-pages -d dist"
  },
  "dependencies": {
    "@astrojs/mdx": "3.1.9",
    "@astrojs/react": "3.6.3",
    "@astrojs/sitemap": "3.2.1",
    "@astrojs/tailwind": "5.1.4",
    "astro": "4.16.18",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwindcss": "3.4.17"
  },
  "devDependencies": {
    "@axe-core/cli": "4.10.1",
    "@lhci/cli": "0.14.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@typescript-eslint/eslint-plugin": "8.18.1",
    "@typescript-eslint/parser": "8.18.1",
    "@vercel/og": "0.6.5",
    "astro-eslint-parser": "1.0.3",
    "decap-cms-app": "3.5.0",
    "eslint": "9.16.0",
    "eslint-plugin-astro": "1.3.1",
    "gh-pages": "^6.3.0",
    "linkinator": "6.1.2",
    "pagefind": "1.1.1",
    "prettier": "3.3.3",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "5.6.3"
  }
}
