---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About — MKU Centre for Placenta Research"
  description="Learn about Africa's first dedicated centre for placental and pregnancy-disease research at Mount Kenya University."
  audience="scientific"
>
  <!-- Hero Section -->
  <section class="relative py-20 bg-gradient-to-br from-accent-primary to-accent-secondary overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-[url('https://picsum.photos/seed/mount-kenya-university-campus-africa-education-research/1920/1080.jpg')] bg-cover bg-center opacity-20"></div>
      <div class="absolute inset-0 bg-black/40"></div>
    </div>
    
    <div class="container-prose relative z-10 text-white">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center px-6 py-3 bg-white/20 backdrop-blur-md text-white text-sm font-semibold rounded-full mb-8 border border-white/30">
          🎓 About Us
        </div>
        <h1 class="text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Africa's First Dedicated Centre for 
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-accent-secondary">
            Placental Research
          </span>
        </h1>
        <p class="text-xl lg:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed">
          The MKU Centre for Placenta Research is pioneering the study of placental and pregnancy diseases in Africa, 
          combining cutting-edge research with community impact to transform maternal health outcomes across the continent.
        </p>
      </div>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="py-20 bg-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Our Purpose</h2>
        <p class="text-xl text-ink-600">Guided by mission, driven by vision</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Mission -->
        <article class="group relative bg-gradient-to-br from-accent-primary/5 to-accent-secondary/5 rounded-3xl p-8 border border-accent-primary/20 hover:shadow-2xl transition-all duration-300">
          <div class="text-center mb-6">
            <div class="w-20 h-20 bg-gradient-to-br from-accent-primary to-accent-secondary rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
              🎯
            </div>
            <h3 class="text-3xl font-bold text-ink-900 mb-4">Our Mission</h3>
          </div>
          <p class="text-lg text-ink-700 leading-relaxed text-center">
            To discover, diagnose, and dismantle the diseases of pregnancy through innovative research, 
            advanced diagnostics, and community engagement, ensuring healthier outcomes for mothers and babies across Africa.
          </p>
          <div class="mt-6 flex justify-center">
            <div class="flex items-center gap-2 px-4 py-2 bg-accent-primary/10 text-accent-primary rounded-full">
              <div class="w-2 h-2 bg-accent-primary rounded-full animate-pulse"></div>
              <span class="text-sm font-semibold">Active Mission</span>
            </div>
          </div>
        </article>

        <!-- Vision -->
        <article class="group relative bg-gradient-to-br from-accent-secondary/5 to-accent-tertiary/5 rounded-3xl p-8 border border-accent-secondary/20 hover:shadow-2xl transition-all duration-300">
          <div class="text-center mb-6">
            <div class="w-20 h-20 bg-gradient-to-br from-accent-secondary to-accent-tertiary rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
              👁️
            </div>
            <h3 class="text-3xl font-bold text-ink-900 mb-4">Our Vision</h3>
          </div>
          <p class="text-lg text-ink-700 leading-relaxed text-center">
            A future where no mother or baby suffers from preventable placental diseases, 
            where Africa leads the world in pregnancy research, and where scientific breakthroughs 
            reach every community that needs them.
          </p>
          <div class="mt-6 flex justify-center">
            <div class="flex items-center gap-2 px-4 py-2 bg-accent-secondary/10 text-accent-secondary rounded-full">
              <div class="w-2 h-2 bg-accent-secondary rounded-full animate-pulse"></div>
              <span class="text-sm font-semibold">Future Focused</span>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- About MKU -->
  <section class="py-20 bg-gradient-to-b from-ink-50 to-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">About Mount Kenya University</h2>
        <p class="text-xl text-ink-600">A leading institution fostering research excellence</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1">
          <div class="bg-white rounded-3xl shadow-xl p-8 border border-ink-100">
            <h3 class="text-2xl font-bold text-ink-900 mb-6">Leading Private University in Kenya</h3>
            <p class="text-lg text-ink-700 leading-relaxed mb-6">
              Mount Kenya University (MKU) is a leading private university in Kenya, committed to excellence in education, 
              research, and community service. With a strong focus on health sciences and research innovation, 
              MKU provides the ideal environment for groundbreaking placental research.
            </p>
            
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
              <div class="text-center p-4 bg-accent-primary/5 rounded-xl">
                <div class="text-3xl font-bold text-accent-primary mb-2">15+</div>
                <div class="text-sm text-ink-600 font-medium">Years of Excellence</div>
              </div>
              <div class="text-center p-4 bg-accent-secondary/5 rounded-xl">
                <div class="text-3xl font-bold text-accent-secondary mb-2">50K+</div>
                <div class="text-sm text-ink-600 font-medium">Students</div>
              </div>
              <div class="text-center p-4 bg-accent-tertiary/5 rounded-xl">
                <div class="text-3xl font-bold text-accent-tertiary mb-2">200+</div>
                <div class="text-sm text-ink-600 font-medium">Programs</div>
              </div>
            </div>
          </div>
        </div>
        
        <div class="order-1 lg:order-2">
          <div class="relative">
            <div class="w-full h-96 bg-gradient-to-br from-accent-primary/20 to-accent-secondary/20 rounded-3xl overflow-hidden shadow-xl">
              <div class="w-full h-full bg-[url('https://picsum.photos/seed/mount-kenya-university-campus-buildings-africa-education/600/400.jpg')] bg-cover bg-center"></div>
            </div>
            <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-accent-primary rounded-2xl flex items-center justify-center text-white text-2xl font-bold shadow-lg">
              MKU
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Research Focus Areas -->
  <section class="py-20 bg-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Research Focus Areas</h2>
        <p class="text-xl text-ink-600">Pioneering research in critical maternal health areas</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Malaria Research -->
        <article class="group bg-gradient-to-br from-accent-primary/5 to-accent-primary/10 rounded-2xl p-6 border border-accent-primary/20 hover:shadow-xl transition-all duration-300">
          <div class="w-16 h-16 bg-accent-primary rounded-2xl flex items-center justify-center text-white text-2xl font-bold mb-4 group-hover:scale-110 transition-transform duration-300">
            🦟
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-3">Malaria in Pregnancy</h3>
          <p class="text-ink-600 leading-relaxed">
            Understanding how malaria affects placental development and developing innovative diagnostic tools for early detection.
          </p>
        </article>

        <!-- Diagnostic Innovation -->
        <article class="group bg-gradient-to-br from-accent-secondary/5 to-accent-secondary/10 rounded-2xl p-6 border border-accent-secondary/20 hover:shadow-xl transition-all duration-300">
          <div class="w-16 h-16 bg-accent-secondary rounded-2xl flex items-center justify-center text-white text-2xl font-bold mb-4 group-hover:scale-110 transition-transform duration-300">
            🔬
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-3">Diagnostic Innovation</h3>
          <p class="text-ink-600 leading-relaxed">
            Developing rapid, affordable point-of-care diagnostic tools for placental diseases in resource-limited settings.
          </p>
        </article>

        <!-- Maternal Health -->
        <article class="group bg-gradient-to-br from-accent-tertiary/5 to-accent-tertiary/10 rounded-2xl p-6 border border-accent-tertiary/20 hover:shadow-xl transition-all duration-300">
          <div class="w-16 h-16 bg-accent-tertiary rounded-2xl flex items-center justify-center text-white text-2xl font-bold mb-4 group-hover:scale-110 transition-transform duration-300">
            🤰
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-3">Maternal Health</h3>
          <p class="text-ink-600 leading-relaxed">
            Investigating the molecular mechanisms of placental disorders and identifying potential therapeutic interventions.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Leadership Team -->
  <section class="py-20 bg-gradient-to-b from-white to-ink-50">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Leadership Team</h2>
        <p class="text-xl text-ink-600">Expert researchers and healthcare professionals</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Director -->
        <article class="text-center group">
          <div class="relative mb-6">
            <div class="w-32 h-32 mx-auto bg-gradient-to-br from-accent-primary to-accent-secondary rounded-full overflow-hidden shadow-lg group-hover:shadow-xl transition-shadow duration-300">
              <div class="w-full h-full bg-[url('https://picsum.photos/seed/professional-director-researcher-scientist-portrait/200/200.jpg')] bg-cover bg-center"></div>
            </div>
            <div class="absolute bottom-0 right-1/3 w-8 h-8 bg-green-500 rounded-full border-4 border-white"></div>
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-2">Prof. Jesse Gitaka</h3>
          <p class="text-accent-primary font-semibold mb-2">Director</p>
          <p class="text-ink-600 text-sm leading-relaxed">
            Leading expert in placental malaria research with over 15 years of experience in maternal health.
          </p>
        </article>

        <!-- Deputy Director -->
        <article class="text-center group">
          <div class="relative mb-6">
            <div class="w-32 h-32 mx-auto bg-gradient-to-br from-accent-secondary to-accent-tertiary rounded-full overflow-hidden shadow-lg group-hover:shadow-xl transition-shadow duration-300">
              <div class="w-full h-full bg-[url('https://picsum.photos/seed/professional-deputy-director-female-scientist-researcher/200/200.jpg')] bg-cover bg-center"></div>
            </div>
            <div class="absolute bottom-0 right-1/3 w-8 h-8 bg-green-500 rounded-full border-4 border-white"></div>
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-2">Dr. Sarah Kimani</h3>
          <p class="text-accent-secondary font-semibold mb-2">Deputy Director</p>
          <p class="text-ink-600 text-sm leading-relaxed">
            Specialist in diagnostic innovation and point-of-care testing for placental diseases.
          </p>
        </article>

        <!-- Research Lead -->
        <article class="text-center group">
          <div class="relative mb-6">
            <div class="w-32 h-32 mx-auto bg-gradient-to-br from-accent-tertiary to-accent-quat rounded-full overflow-hidden shadow-lg group-hover:shadow-xl transition-shadow duration-300">
              <div class="w-full h-full bg-[url('https://picsum.photos/seed/professional-research-lead-scientist-laboratory/200/200.jpg')] bg-cover bg-center"></div>
            </div>
            <div class="absolute bottom-0 right-1/3 w-8 h-8 bg-green-500 rounded-full border-4 border-white"></div>
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-2">Dr. Michael Ochieng</h3>
          <p class="text-accent-tertiary font-semibold mb-2">Research Lead</p>
          <p class="text-ink-600 text-sm leading-relaxed">
            Expert in molecular biology and immunology of placental infections.
          </p>
        </article>

        <!-- Community Lead -->
        <article class="text-center group">
          <div class="relative mb-6">
            <div class="w-32 h-32 mx-auto bg-gradient-to-br from-accent-quat to-accent-violet rounded-full overflow-hidden shadow-lg group-hover:shadow-xl transition-shadow duration-300">
              <div class="w-full h-full bg-[url('https://picsum.photos/seed/professional-community-lead-public-health-specialist/200/200.jpg')] bg-cover bg-center"></div>
            </div>
            <div class="absolute bottom-0 right-1/3 w-8 h-8 bg-green-500 rounded-full border-4 border-white"></div>
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-2">Dr. Grace Wanjiru</h3>
          <p class="text-accent-quat font-semibold mb-2">Community Lead</p>
          <p class="text-ink-600 text-sm leading-relaxed">
            Specialist in community engagement and maternal health program implementation.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-20 bg-gradient-to-r from-accent-primary to-accent-secondary">
    <div class="container-prose text-center text-white">
      <h2 class="text-4xl font-bold mb-6">Join Our Mission</h2>
      <p class="text-xl mb-8 max-w-3xl mx-auto">
        Together, we can transform maternal health outcomes across Africa through innovative research, 
        community engagement, and sustainable healthcare solutions.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <button class="px-8 py-4 bg-gradient-to-r from-accent-primary to-accent-secondary text-white font-bold rounded-xl hover:from-accent-secondary hover:to-accent-tertiary transition-all duration-300 transform hover:scale-105 shadow-lg">
          Partner With Us
        </button>
        <button class="px-8 py-4 bg-transparent border-2 border-accent-tertiary text-accent-tertiary font-bold rounded-xl hover:bg-accent-tertiary hover:text-white transition-all duration-200">
          Learn More
        </button>
      </div>
    </div>
  </section>
</BaseLayout>
