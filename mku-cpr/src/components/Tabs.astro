---
interface Tab {
  id: string;
  label: string;
  active?: boolean;
}

interface Props {
  tabs: Tab[];
  id?: string;
  class?: string;
}

const { tabs, id = "tabs-" + Math.random().toString(36).substr(2, 9), class: className } = Astro.props;
---

<div class={`cpr-tabs ${className}`} id={id} data-tabs>
  <div class="flex border-b border-ink-100 overflow-x-auto no-scrollbar" role="tablist">
    {tabs.map((tab) => (
      <button
        class={`px-sp-6 py-sp-3 text-step--1 font-medium transition-all duration-200 border-b-2 -mb-[2px] whitespace-nowrap
          ${tab.active 
            ? 'border-accent-primary text-ink-900 bg-snow' 
            : 'border-transparent text-ink-500 hover:text-ink-700 hover:bg-ink-100/50'
          }`}
        role="tab"
        aria-selected={tab.active ? "true" : "false"}
        aria-controls={`${id}-panel-${tab.id}`}
        id={`${id}-tab-${tab.id}`}
        data-tab-id={tab.id}
      >
        {tab.label}
      </button>
    ))}
  </div>

  <div class="mt-sp-6">
    <slot />
  </div>
</div>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  class TabsManager {
    container: HTMLElement;
    tabs: HTMLButtonElement[];
    panels: HTMLElement[];

    constructor(container: HTMLElement) {
      this.container = container;
      this.tabs = Array.from(container.querySelectorAll('[role="tab"]'));
      this.panels = Array.from(container.querySelectorAll('[role="tabpanel"]'));

      this.init();
    }

    init() {
      this.tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const tabId = tab.getAttribute('data-tab-id');
          this.switchTab(tabId);
        });
      });
    }

    switchTab(id: string | null) {
      if (!id) return;

      this.tabs.forEach((tab) => {
        const isSelected = tab.getAttribute('data-tab-id') === id;
        tab.setAttribute('aria-selected', isSelected ? 'true' : 'false');
        tab.classList.toggle('border-accent-primary', isSelected);
        tab.classList.toggle('text-ink-900', isSelected);
        tab.classList.toggle('bg-snow', isSelected);
        tab.classList.toggle('border-transparent', !isSelected);
        tab.classList.toggle('text-ink-500', !isSelected);
      });

      this.panels.forEach((panel) => {
        const isSelected = panel.getAttribute('id')?.endsWith(`panel-${id}`);
        panel.classList.toggle('hidden', !isSelected);
      });
    }
  }

  // Initialize all tabs on the page
  const tabContainers = document.querySelectorAll('[data-tabs]');
  tabContainers.forEach((container) => {
    new TabsManager(container as HTMLElement);
  });
</script>
