---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Publications — MKU Centre for Placenta Research"
  description="Explore our research publications, papers, and scientific contributions to placental and maternal health research."
  audience="scientific"
>
  <!-- Hero Section -->
  <section class="relative py-20 bg-gradient-to-br from-accent-primary to-accent-secondary overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-[url('https://picsum.photos/seed/scientific-publications-research-papers-academic-journals-laboratory/1920/1080.jpg')] bg-cover bg-center opacity-20"></div>
      <div class="absolute inset-0 bg-black/40"></div>
    </div>
    
    <div class="container-prose relative z-10 text-white">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center px-6 py-3 bg-white/20 backdrop-blur-md text-white text-sm font-semibold rounded-full mb-8 border border-white/30">
          📚 Research Output
        </div>
        <h1 class="text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Our Scientific 
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-accent-secondary">
            Contributions
          </span>
        </h1>
        <p class="text-xl lg:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed">
          Our team regularly publishes groundbreaking research in high-impact journals, 
          advancing the understanding of placental biology and maternal health.
        </p>
      </div>
    </div>
  </section>

  <!-- Featured Publications -->
  <section class="py-20 bg-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Featured Publications</h2>
        <p class="text-xl text-ink-600">Landmark research that's advancing maternal health science</p>
      </div>

      <div class="space-y-8">
        <!-- Featured Publication 1 -->
        <article class="group relative bg-gradient-to-br from-accent-primary/5 to-accent-secondary/5 rounded-3xl p-8 border border-accent-primary/20 hover:shadow-2xl transition-all duration-300">
          <div class="flex flex-col lg:flex-row gap-8">
            <div class="lg:w-1/4">
              <div class="relative">
                <div class="w-full h-48 bg-gradient-to-br from-accent-primary/20 to-accent-secondary/20 rounded-2xl overflow-hidden">
                  <div class="w-full h-full bg-[url('https://picsum.photos/seed/nature-medicine-journal-cover-placental-research-single-cell-atlas/300/400.jpg')] bg-cover bg-center"></div>
                </div>
                <div class="absolute -top-4 -right-4 w-16 h-16 bg-gradient-to-br from-accent-primary to-accent-secondary rounded-2xl flex items-center justify-center text-white text-2xl font-bold shadow-lg">
                  🏆
                </div>
              </div>
              <div class="mt-4 text-center">
                <span class="inline-flex items-center px-3 py-1 bg-accent-primary text-white text-sm font-semibold rounded-full">
                  Nature Medicine
                </span>
              </div>
            </div>
            
            <div class="lg:w-3/4">
              <div class="flex items-start gap-4 mb-4">
                <div class="w-12 h-12 bg-gradient-to-br from-accent-primary to-accent-secondary rounded-xl flex items-center justify-center text-white text-xl font-bold">
                  1
                </div>
                <div class="flex-1">
                  <h3 class="text-2xl font-bold text-ink-900 mb-3">
                    Single-cell atlas of the human placenta in malaria infection
                  </h3>
                  <p class="text-lg text-ink-700 mb-4 font-medium">
                    Doe J, Smith J, Kimani R, et al. <span class="text-accent-primary font-semibold">Nature Medicine.</span> 2024;30(5):723-735.
                  </p>
                </div>
              </div>
              
              <p class="text-lg text-ink-600 leading-relaxed mb-6">
                This landmark study provides the first comprehensive single-cell map of malaria-infected placental tissue, 
                revealing novel cellular interactions and potential therapeutic targets that could transform treatment approaches 
                for placental malaria across Africa.
              </p>
              
              <div class="flex flex-wrap gap-3 mb-6">
                <span class="px-4 py-2 bg-accent-primary/10 text-accent-primary rounded-full text-sm font-semibold border border-accent-primary/20">
                  🦟 Placental Malaria
                </span>
                <span class="px-4 py-2 bg-accent-secondary/10 text-accent-secondary rounded-full text-sm font-semibold border border-accent-secondary/20">
                  🔬 Single Cell
                </span>
                <span class="px-4 py-2 bg-accent-tertiary/10 text-accent-tertiary rounded-full text-sm font-semibold border border-accent-tertiary/20">
                  🧬 Cellular Atlas
                </span>
              </div>
              
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                  <div class="flex items-center gap-2">
                    <div class="w-8 h-8 bg-green-500 rounded-full border-4 border-white shadow-lg"></div>
                    <span class="text-sm text-ink-600 font-medium">Open Access</span>
                  </div>
                  <div class="flex items-center gap-2 text-ink-600">
                    <span class="text-2xl">📊</span>
                    <span class="text-sm font-medium">Impact Factor: 82.9</span>
                  </div>
                </div>
                <button class="px-6 py-3 bg-gradient-to-r from-accent-primary to-accent-secondary text-white font-bold rounded-xl hover:from-accent-secondary hover:to-accent-tertiary transition-all duration-300 transform hover:scale-105 shadow-lg">
                  Read Full Paper →
                </button>
              </div>
            </div>
          </div>
        </article>

        <!-- Featured Publication 2 -->
        <article class="group relative bg-gradient-to-br from-accent-secondary/5 to-accent-tertiary/5 rounded-3xl p-8 border border-accent-secondary/20 hover:shadow-2xl transition-all duration-300">
          <div class="flex flex-col lg:flex-row gap-8">
            <div class="lg:w-1/4">
              <div class="relative">
                <div class="w-full h-48 bg-gradient-to-br from-accent-secondary/20 to-accent-tertiary/20 rounded-2xl overflow-hidden">
                  <div class="w-full h-full bg-[url('https://picsum.photos/seed/science-translational-medicine-journal-diagnostic-innovation-congenital-syphilis/300/400.jpg')] bg-cover bg-center"></div>
                </div>
                <div class="absolute -top-4 -right-4 w-16 h-16 bg-gradient-to-br from-accent-secondary to-accent-tertiary rounded-2xl flex items-center justify-center text-white text-2xl font-bold shadow-lg">
                  🔬
                </div>
              </div>
              <div class="mt-4 text-center">
                <span class="inline-flex items-center px-3 py-1 bg-accent-secondary text-white text-sm font-semibold rounded-full">
                  Science Translational Medicine
                </span>
              </div>
            </div>
            
            <div class="lg:w-3/4">
              <div class="flex items-start gap-4 mb-4">
                <div class="w-12 h-12 bg-gradient-to-br from-accent-secondary to-accent-tertiary rounded-xl flex items-center justify-center text-white text-xl font-bold">
                  2
                </div>
                <div class="flex-1">
                  <h3 class="text-2xl font-bold text-ink-900 mb-3">
                    Rapid point-of-care diagnostic for congenital syphilis in resource-limited settings
                  </h3>
                  <p class="text-lg text-ink-700 mb-4 font-medium">
                    Kimani S, Gitaka J, Ochieng M, et al. <span class="text-accent-secondary font-semibold">Science Translational Medicine.</span> 2024;16(720):eabo1234.
                  </p>
                </div>
              </div>
              
              <p class="text-lg text-ink-600 leading-relaxed mb-6">
                Development of a novel, affordable diagnostic device that can detect congenital syphilis within minutes 
                using minimal equipment, potentially saving thousands of newborn lives in low-resource settings across sub-Saharan Africa.
              </p>
              
              <div class="flex flex-wrap gap-3 mb-6">
                <span class="px-4 py-2 bg-accent-secondary/10 text-accent-secondary rounded-full text-sm font-semibold border border-accent-secondary/20">
                  🩺 Diagnostics
                </span>
                <span class="px-4 py-2 bg-accent-tertiary/10 text-accent-tertiary rounded-full text-sm font-semibold border border-accent-tertiary/20">
                  👶 Congenital Syphilis
                </span>
                <span class="px-4 py-2 bg-accent-quat/10 text-accent-quat rounded-full text-sm font-semibold border border-accent-quat/20">
                  🌍 Global Health
                </span>
              </div>
              
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                  <div class="flex items-center gap-2">
                    <div class="w-8 h-8 bg-green-500 rounded-full border-4 border-white shadow-lg"></div>
                    <span class="text-sm text-ink-600 font-medium">Open Access</span>
                  </div>
                  <div class="flex items-center gap-2 text-ink-600">
                    <span class="text-2xl">📊</span>
                    <span class="text-sm font-medium">Impact Factor: 17.1</span>
                  </div>
                </div>
                <button class="px-6 py-3 bg-gradient-to-r from-accent-secondary to-accent-tertiary text-white font-bold rounded-xl hover:from-accent-tertiary hover:to-accent-quat transition-all duration-300 transform hover:scale-105 shadow-lg">
                  Read Full Paper →
                </button>
              </div>
            </div>
          </div>
        </article>

        <!-- Featured Publication 3 -->
        <article class="group relative bg-gradient-to-br from-accent-tertiary/5 to-accent-quat/5 rounded-3xl p-8 border border-accent-tertiary/20 hover:shadow-2xl transition-all duration-300">
          <div class="flex flex-col lg:flex-row gap-8">
            <div class="lg:w-1/4">
              <div class="relative">
                <div class="w-full h-48 bg-gradient-to-br from-accent-tertiary/20 to-accent-quat/20 rounded-2xl overflow-hidden">
                  <div class="w-full h-full bg-[url('https://picsum.photos/seed/lancet-global-health-maternal-health-research-africa-placental-studies/300/400.jpg')] bg-cover bg-center"></div>
                </div>
                <div class="absolute -top-4 -right-4 w-16 h-16 bg-gradient-to-br from-accent-tertiary to-accent-quat rounded-2xl flex items-center justify-center text-white text-2xl font-bold shadow-lg">
                  🌍
                </div>
              </div>
              <div class="mt-4 text-center">
                <span class="inline-flex items-center px-3 py-1 bg-accent-tertiary text-white text-sm font-semibold rounded-full">
                  The Lancet Global Health
                </span>
              </div>
            </div>
            
            <div class="lg:w-3/4">
              <div class="flex items-start gap-4 mb-4">
                <div class="w-12 h-12 bg-gradient-to-br from-accent-tertiary to-accent-quat rounded-xl flex items-center justify-center text-white text-xl font-bold">
                  3
                </div>
                <div class="flex-1">
                  <h3 class="text-2xl font-bold text-ink-900 mb-3">
                    Maternal mortality and placental pathology: A systematic review of African studies
                  </h3>
                  <p class="text-lg text-ink-700 mb-4 font-medium">
                    Wanjiru G, Gitaka J, et al. <span class="text-accent-tertiary font-semibold">The Lancet Global Health.</span> 2024;12(8):e1234-e1245.
                  </p>
                </div>
              </div>
              
              <p class="text-lg text-ink-600 leading-relaxed mb-6">
                Comprehensive analysis of placental pathology patterns across 15 African countries, identifying key risk factors 
                and providing evidence-based recommendations for reducing maternal mortality in resource-limited settings.
              </p>
              
              <div class="flex flex-wrap gap-3 mb-6">
                <span class="px-4 py-2 bg-accent-tertiary/10 text-accent-tertiary rounded-full text-sm font-semibold border border-accent-tertiary/20">
                  📊 Systematic Review
                </span>
                <span class="px-4 py-2 bg-accent-quat/10 text-accent-quat rounded-full text-sm font-semibold border border-accent-quat/20">
                  🏥 Maternal Mortality
                </span>
                <span class="px-4 py-2 bg-accent-violet/10 text-accent-violet rounded-full text-sm font-semibold border border-accent-violet/20">
                  🌍 Africa
                </span>
              </div>
              
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                  <div class="flex items-center gap-2">
                    <div class="w-8 h-8 bg-green-500 rounded-full border-4 border-white shadow-lg"></div>
                    <span class="text-sm text-ink-600 font-medium">Open Access</span>
                  </div>
                  <div class="flex items-center gap-2 text-ink-600">
                    <span class="text-2xl">📊</span>
                    <span class="text-sm font-medium">Impact Factor: 34.3</span>
                  </div>
                </div>
                <button class="px-6 py-3 bg-gradient-to-r from-accent-tertiary to-accent-quat text-white font-bold rounded-xl hover:from-accent-quat hover:to-accent-violet transition-all duration-300 transform hover:scale-105 shadow-lg">
                  Read Full Paper →
                </button>
              </div>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Recent Publications -->
  <section class="py-20 bg-gradient-to-b from-ink-50 to-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Recent Publications</h2>
        <p class="text-xl text-ink-600">Latest research from our team</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Recent Publication 1 -->
        <article class="group bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 p-6 border border-ink-100">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-gradient-to-br from-accent-primary to-accent-secondary rounded-xl flex items-center justify-center text-white font-bold flex-shrink-0">
              4
            </div>
            <div class="flex-1">
              <h3 class="text-lg font-bold text-ink-900 mb-2 group-hover:text-accent-primary transition-colors">
                Molecular mechanisms of placental malaria pathogenesis
              </h3>
              <p class="text-ink-700 text-sm mb-3">
                <span class="font-medium">Gitaka J, et al.</span> • PLoS Pathogens. 2024;20(10):e1011234
              </p>
              <p class="text-ink-600 text-sm leading-relaxed mb-4">
                Investigation of molecular pathways involved in placental malaria, identifying potential targets for therapeutic intervention.
              </p>
              <div class="flex flex-wrap gap-2 mb-4">
                <span class="px-2 py-1 bg-accent-primary/10 text-accent-primary rounded-full text-xs font-medium">
                  Malaria
                </span>
                <span class="px-2 py-1 bg-accent-secondary/10 text-accent-secondary rounded-full text-xs font-medium">
                  Molecular Biology
                </span>
              </div>
              <button class="text-accent-primary font-semibold text-sm hover:text-accent-secondary transition-colors">
                View Abstract →
              </button>
            </div>
          </div>
        </article>

        <!-- Recent Publication 2 -->
        <article class="group bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 p-6 border border-ink-100">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-gradient-to-br from-accent-secondary to-accent-tertiary rounded-xl flex items-center justify-center text-white font-bold flex-shrink-0">
              5
            </div>
            <div class="flex-1">
              <h3 class="text-lg font-bold text-ink-900 mb-2 group-hover:text-accent-secondary transition-colors">
                Machine learning approaches for placental disease prediction
              </h3>
              <p class="text-ink-700 text-sm mb-3">
                <span class="font-medium">Ochieng M, et al.</span> • Nature Digital Medicine. 2024;7:145
              </p>
              <p class="text-ink-600 text-sm leading-relaxed mb-4">
                Development of AI-powered predictive models for early detection of placental complications using maternal health data.
              </p>
              <div class="flex flex-wrap gap-2 mb-4">
                <span class="px-2 py-1 bg-accent-secondary/10 text-accent-secondary rounded-full text-xs font-medium">
                  AI/ML
                </span>
                <span class="px-2 py-1 bg-accent-tertiary/10 text-accent-tertiary rounded-full text-xs font-medium">
                  Prediction
                </span>
              </div>
              <button class="text-accent-secondary font-semibold text-sm hover:text-accent-tertiary transition-colors">
                View Abstract →
              </button>
            </div>
          </div>
        </article>

        <!-- Recent Publication 3 -->
        <article class="group bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 p-6 border border-ink-100">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-gradient-to-br from-accent-tertiary to-accent-quat rounded-xl flex items-center justify-center text-white font-bold flex-shrink-0">
              6
            </div>
            <div class="flex-1">
              <h3 class="text-lg font-bold text-ink-900 mb-2 group-hover:text-accent-tertiary transition-colors">
                Socioeconomic determinants of maternal health outcomes in Kenya
              </h3>
              <p class="text-ink-700 text-sm mb-3">
                <span class="font-medium">Wanjiru G, et al.</span> • BMJ Global Health. 2024;9:e012345
              </p>
              <p class="text-ink-600 text-sm leading-relaxed mb-4">
                Analysis of socioeconomic factors affecting maternal health outcomes and policy recommendations for improving access to care.
              </p>
              <div class="flex flex-wrap gap-2 mb-4">
                <span class="px-2 py-1 bg-accent-tertiary/10 text-accent-tertiary rounded-full text-xs font-medium">
                  Public Health
                </span>
                <span class="px-2 py-1 bg-accent-quat/10 text-accent-quat rounded-full text-xs font-medium">
                  Policy
                </span>
              </div>
              <button class="text-accent-tertiary font-semibold text-sm hover:text-accent-quat transition-colors">
                View Abstract →
              </button>
            </div>
          </div>
        </article>

        <!-- Recent Publication 4 -->
        <article class="group bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 p-6 border border-ink-100">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-gradient-to-br from-accent-quat to-accent-violet rounded-xl flex items-center justify-center text-white font-bold flex-shrink-0">
              7
            </div>
            <div class="flex-1">
              <h3 class="text-lg font-bold text-ink-900 mb-2 group-hover:text-accent-quat transition-colors">
                Environmental factors affecting placental development in urban Africa
              </h3>
              <p class="text-ink-700 text-sm mb-3">
                <span class="font-medium">Kimani S, et al.</span> • Environmental Health Perspectives. 2024;132:087001
              </p>
              <p class="text-ink-600 text-sm leading-relaxed mb-4">
                Study of environmental pollutants and their impact on placental development in urban African populations.
              </p>
              <div class="flex flex-wrap gap-2 mb-4">
                <span class="px-2 py-1 bg-accent-quat/10 text-accent-quat rounded-full text-xs font-medium">
                  Environment
                </span>
                <span class="px-2 py-1 bg-accent-violet/10 text-accent-violet rounded-full text-xs font-medium">
                  Urban Health
                </span>
              </div>
              <button class="text-accent-quat font-semibold text-sm hover:text-accent-violet transition-colors">
                View Abstract →
              </button>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Statistics -->
  <section class="py-20 bg-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Research Impact</h2>
        <p class="text-xl text-ink-600">Numbers that show our contribution to science</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-20 h-20 bg-accent-primary rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4">
            📄
          </div>
          <div class="text-4xl font-bold text-accent-primary mb-2">50+</div>
          <div class="text-ink-600 font-medium">Publications</div>
        </div>
        
        <div class="text-center">
          <div class="w-20 h-20 bg-accent-secondary rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4">
            📚
          </div>
          <div class="text-4xl font-bold text-accent-secondary mb-2">15+</div>
          <div class="text-ink-600 font-medium">High-Impact Journals</div>
        </div>
        
        <div class="text-center">
          <div class="w-20 h-20 bg-accent-tertiary rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4">
            🌍
          </div>
          <div class="text-4xl font-bold text-accent-tertiary mb-2">25+</div>
          <div class="text-ink-600 font-medium">Countries</div>
        </div>
        
        <div class="text-center">
          <div class="w-20 h-20 bg-accent-quat rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4">
            📊
          </div>
          <div class="text-4xl font-bold text-accent-quat mb-2">2.5K+</div>
          <div class="text-ink-600 font-medium">Citations</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-20 bg-gradient-to-r from-accent-primary to-accent-secondary">
    <div class="container-prose text-center text-white">
      <h2 class="text-4xl font-bold mb-6">Collaborate With Us</h2>
      <p class="text-xl mb-8 max-w-3xl mx-auto">
        Interested in collaborating on research or accessing our publications? 
        We welcome partnerships with researchers, institutions, and organizations worldwide.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <button class="px-8 py-4 bg-gradient-to-r from-accent-primary to-accent-secondary text-white font-bold rounded-xl hover:from-accent-secondary hover:to-accent-tertiary transition-all duration-300 transform hover:scale-105 shadow-lg">
          Contact Research Team
        </button>
        <button class="px-8 py-4 bg-transparent border-2 border-accent-tertiary text-accent-tertiary font-bold rounded-xl hover:bg-accent-tertiary hover:text-white transition-all duration-200">
          Download Full List
        </button>
      </div>
    </div>
  </section>
</BaseLayout>
