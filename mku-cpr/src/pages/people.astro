---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="People — MKU Centre for Placenta Research"
  description="Meet our team of leading researchers, scientists, and staff working to advance maternal health in Africa."
  audience="scientific"
>
  <!-- Hero Section -->
  <section class="relative py-20 bg-gradient-to-br from-accent-primary to-accent-secondary overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-[url('https://picsum.photos/seed/research-team-scientists-laboratory-collaboration/1920/1080.jpg')] bg-cover bg-center opacity-20"></div>
      <div class="absolute inset-0 bg-black/40"></div>
    </div>
    
    <div class="container-prose relative z-10 text-white">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center px-6 py-3 bg-white/20 backdrop-blur-md text-white text-sm font-semibold rounded-full mb-8 border border-white/30">
          👥 Our Research Team
        </div>
        <h1 class="text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Meet Our 
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-accent-secondary">
            Leading Experts
          </span>
        </h1>
        <p class="text-xl lg:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed">
          Our multidisciplinary team brings together expertise from molecular biology, clinical medicine, 
          data science, and public health to tackle the complex challenges of maternal health.
        </p>
      </div>
    </div>
  </section>

  <!-- Principal Investigator -->
  <section class="py-20 bg-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Principal Investigator</h2>
        <p class="text-xl text-ink-600">Leading our research mission with expertise and vision</p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="group relative bg-gradient-to-br from-accent-primary/5 to-accent-secondary/5 rounded-3xl p-8 border border-accent-primary/20 hover:shadow-2xl transition-all duration-300">
          <div class="flex flex-col md:flex-row gap-8 items-center">
            <div class="w-48 h-48 rounded-2xl overflow-hidden flex-shrink-0">
              <div class="w-full h-full bg-[url('https://picsum.photos/seed/professional-african-male-scientist-professor/400/400.jpg')] bg-cover bg-center"></div>
            </div>
            
            <div class="flex-1 text-center md:text-left">
              <div class="inline-flex items-center px-4 py-2 bg-accent-primary text-white text-sm font-semibold rounded-full mb-4">
                🎓 Principal Investigator
              </div>
              <h3 class="text-3xl font-bold text-ink-900 mb-2">Prof. Jesse Gitaka</h3>
              <p class="text-xl text-accent-primary font-semibold mb-4">MBChB, MTropMed, PhD</p>
              <p class="text-ink-600 leading-relaxed mb-6">
                Founding Director of Centre for Malaria Elimination (CME) and Centre for Research in Infectious Diseases (CRID) 
                at Mount Kenya University. Leading expert in tropical medicine, maternal health, and infectious disease research.
              </p>
              <div class="flex flex-wrap gap-2 justify-center md:justify-start">
                <span class="px-3 py-1 bg-accent-primary/10 text-accent-primary text-sm font-medium rounded-full">Malaria Research</span>
                <span class="px-3 py-1 bg-accent-secondary/10 text-accent-secondary text-sm font-medium rounded-full">Maternal Health</span>
                <span class="px-3 py-1 bg-accent-tertiary/10 text-accent-tertiary text-sm font-medium rounded-full">Genomics</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Senior Researchers -->
  <section class="py-20 bg-gradient-to-b from-ink-50 to-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Senior Researchers</h2>
        <p class="text-xl text-ink-600">Our experienced research team driving innovation</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Bernard N. Kanoi -->
        <div class="group relative bg-gradient-to-br from-accent-primary/5 to-accent-primary/10 rounded-2xl p-6 border border-accent-primary/20 hover:shadow-xl transition-all duration-300">
          <div class="text-center">
            <div class="w-32 h-32 rounded-full mx-auto mb-4 overflow-hidden">
              <div class="w-full h-full bg-[url('https://picsum.photos/seed/professional-african-male-researcher-scientist/300/300.jpg')] bg-cover bg-center"></div>
            </div>
            <div class="inline-flex items-center px-3 py-1 bg-accent-primary text-white text-xs font-semibold rounded-full mb-3">
              👨‍🔬 Senior Researcher
            </div>
            <h3 class="text-xl font-bold text-ink-900 mb-1">Bernard N. Kanoi, PhD</h3>
            <p class="text-ink-600 mb-4">Expert in molecular biology and genomic surveillance</p>
            <div class="flex flex-wrap gap-1 justify-center">
              <span class="px-2 py-1 bg-accent-primary/10 text-accent-primary text-xs rounded-full">Genomics</span>
              <span class="px-2 py-1 bg-accent-primary/10 text-accent-primary text-xs rounded-full">Malaria</span>
            </div>
          </div>
        </div>

        <!-- Dr Kobia Francis -->
        <div class="group relative bg-gradient-to-br from-accent-secondary/5 to-accent-secondary/10 rounded-2xl p-6 border border-accent-secondary/20 hover:shadow-xl transition-all duration-300">
          <div class="text-center">
            <div class="w-32 h-32 rounded-full mx-auto mb-4 overflow-hidden">
              <div class="w-full h-full bg-[url('https://picsum.photos/seed/professional-african-male-scientist-laboratory/300/300.jpg')] bg-cover bg-center"></div>
            </div>
            <div class="inline-flex items-center px-3 py-1 bg-accent-secondary text-white text-xs font-semibold rounded-full mb-3">
              👨‍🔬 Senior Researcher
            </div>
            <h3 class="text-xl font-bold text-ink-900 mb-1">Dr Kobia Francis, PhD</h3>
            <p class="text-ink-600 mb-4">Specialist in placental research and biomarker discovery</p>
            <div class="flex flex-wrap gap-1 justify-center">
              <span class="px-2 py-1 bg-accent-secondary/10 text-accent-secondary text-xs rounded-full">Placenta</span>
              <span class="px-2 py-1 bg-accent-secondary/10 text-accent-secondary text-xs rounded-full">Biomarkers</span>
            </div>
          </div>
        </div>

        <!-- Dr Ernest Wandera -->
        <div class="group relative bg-gradient-to-br from-accent-tertiary/5 to-accent-tertiary/10 rounded-2xl p-6 border border-accent-tertiary/20 hover:shadow-xl transition-all duration-300">
          <div class="text-center">
            <div class="w-32 h-32 rounded-full mx-auto mb-4 overflow-hidden">
              <div class="w-full h-full bg-[url('https://picsum.photos/seed/professional-african-male-researcher-academic/300/300.jpg')] bg-cover bg-center"></div>
            </div>
            <div class="inline-flex items-center px-3 py-1 bg-accent-tertiary text-white text-xs font-semibold rounded-full mb-3">
              👨‍🔬 Senior Researcher
            </div>
            <h3 class="text-xl font-bold text-ink-900 mb-1">Dr Ernest Wandera, PhD</h3>
            <p class="text-ink-600 mb-4">Focus on diagnostic development and clinical trials</p>
            <div class="flex flex-wrap gap-1 justify-center">
              <span class="px-2 py-1 bg-accent-tertiary/10 text-accent-tertiary text-xs rounded-full">Diagnostics</span>
              <span class="px-2 py-1 bg-accent-tertiary/10 text-accent-tertiary text-xs rounded-full">Clinical Trials</span>
            </div>
          </div>
        </div>

        <!-- Dr Clement Shiluli -->
        <div class="group relative bg-gradient-to-br from-accent-quat/5 to-accent-quat/10 rounded-2xl p-6 border border-accent-quat/20 hover:shadow-xl transition-all duration-300">
          <div class="text-center">
            <div class="w-32 h-32 rounded-full mx-auto mb-4 overflow-hidden">
              <div class="w-full h-full bg-[url('https://picsum.photos/seed/professional-african-male-scientist-researcher/300/300.jpg')] bg-cover bg-center"></div>
            </div>
            <div class="inline-flex items-center px-3 py-1 bg-accent-quat text-white text-xs font-semibold rounded-full mb-3">
              👨‍🔬 Senior Researcher
            </div>
            <h3 class="text-xl font-bold text-ink-900 mb-1">Dr Clement Shiluli, PhD</h3>
            <p class="text-ink-600 mb-4">Expertise in epidemiology and public health research</p>
            <div class="flex flex-wrap gap-1 justify-center">
              <span class="px-2 py-1 bg-accent-quat/10 text-accent-quat text-xs rounded-full">Epidemiology</span>
              <span class="px-2 py-1 bg-accent-quat/10 text-accent-quat text-xs rounded-full">Public Health</span>
            </div>
          </div>
        </div>

        <!-- Carol Kijogi -->
        <div class="group relative bg-gradient-to-br from-accent-violet/5 to-accent-violet/10 rounded-2xl p-6 border border-accent-violet/20 hover:shadow-xl transition-all duration-300">
          <div class="text-center">
            <div class="w-32 h-32 rounded-full mx-auto mb-4 overflow-hidden">
              <div class="w-full h-full bg-[url('https://picsum.photos/seed/professional-african-female-scientist-researcher/300/300.jpg')] bg-cover bg-center"></div>
            </div>
            <div class="inline-flex items-center px-3 py-1 bg-accent-violet text-white text-xs font-semibold rounded-full mb-3">
              👩‍🔬 Senior Researcher
            </div>
            <h3 class="text-xl font-bold text-ink-900 mb-1">Carol Kijogi, PhD</h3>
            <p class="text-ink-600 mb-4">Specialist in immunology and vaccine development</p>
            <div class="flex flex-wrap gap-1 justify-center">
              <span class="px-2 py-1 bg-accent-violet/10 text-accent-violet text-xs rounded-full">Immunology</span>
              <span class="px-2 py-1 bg-accent-violet/10 text-accent-violet text-xs rounded-full">Vaccines</span>
            </div>
          </div>
        </div>

        <!-- Samuel Mbugua -->
        <div class="group relative bg-gradient-to-br from-accent-coral/5 to-accent-coral/10 rounded-2xl p-6 border border-accent-coral/20 hover:shadow-xl transition-all duration-300">
          <div class="text-center">
            <div class="w-32 h-32 rounded-full mx-auto mb-4 overflow-hidden">
              <div class="w-full h-full bg-[url('https://picsum.photos/seed/professional-african-male-scientist-lab-coat/300/300.jpg')] bg-cover bg-center"></div>
            </div>
            <div class="inline-flex items-center px-3 py-1 bg-accent-coral text-white text-xs font-semibold rounded-full mb-3">
              👨‍🔬 Senior Researcher
            </div>
            <h3 class="text-xl font-bold text-ink-900 mb-1">Samuel Mbugua, PhD</h3>
            <p class="text-ink-600 mb-4">Expert in implementation science and health systems</p>
            <div class="flex flex-wrap gap-1 justify-center">
              <span class="px-2 py-1 bg-accent-coral/10 text-accent-coral text-xs rounded-full">Implementation</span>
              <span class="px-2 py-1 bg-accent-coral/10 text-accent-coral text-xs rounded-full">Health Systems</span>
            </div>
          </div>
        </div>

        <!-- Josiah Kuja -->
        <div class="group relative bg-gradient-to-br from-accent-teal/5 to-accent-teal/10 rounded-2xl p-6 border border-accent-teal/20 hover:shadow-xl transition-all duration-300">
          <div class="text-center">
            <div class="w-32 h-32 rounded-full mx-auto mb-4 overflow-hidden">
              <div class="w-full h-full bg-[url('https://picsum.photos/seed/professional-african-male-scientist-medical/300/300.jpg')] bg-cover bg-center"></div>
            </div>
            <div class="inline-flex items-center px-3 py-1 bg-accent-teal text-white text-xs font-semibold rounded-full mb-3">
              👨‍🔬 Senior Researcher
            </div>
            <h3 class="text-xl font-bold text-ink-900 mb-1">Josiah Kuja, PhD</h3>
            <p class="text-ink-600 mb-4">Focus on molecular diagnostics and point-of-care testing</p>
            <div class="flex flex-wrap gap-1 justify-center">
              <span class="px-2 py-1 bg-accent-teal/10 text-accent-teal text-xs rounded-full">Diagnostics</span>
              <span class="px-2 py-1 bg-accent-teal/10 text-accent-teal text-xs rounded-full">POC Testing</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Lab Members -->
  <section class="py-20 bg-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Lab Members</h2>
        <p class="text-xl text-ink-600">Our dedicated team of researchers and support staff</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Racheal Kimani -->
        <div class="text-center group">
          <div class="w-24 h-24 rounded-full mx-auto mb-3 overflow-hidden ring-4 ring-accent-primary/20 group-hover:ring-accent-primary/40 transition-all duration-300">
            <div class="w-full h-full bg-[url('https://picsum.photos/seed/professional-african-female-researcher-young/200/200.jpg')] bg-cover bg-center"></div>
          </div>
          <h4 class="font-semibold text-ink-900">Racheal Kimani, PhD</h4>
          <p class="text-sm text-ink-600">Research Scientist</p>
        </div>

        <!-- Lucy Mwai Gichuki -->
        <div class="text-center group">
          <div class="w-24 h-24 rounded-full mx-auto mb-3 overflow-hidden ring-4 ring-accent-secondary/20 group-hover:ring-accent-secondary/40 transition-all duration-300">
            <div class="w-full h-full bg-[url('https://picsum.photos/seed/professional-african-female-laboratory-technician/200/200.jpg')] bg-cover bg-center"></div>
          </div>
          <h4 class="font-semibold text-ink-900">Lucy Mwai Gichuki</h4>
          <p class="text-sm text-ink-600">Lab Technician</p>
        </div>

        <!-- Patrick Nding'uri -->
        <div class="text-center group">
          <div class="w-24 h-24 rounded-full mx-auto mb-3 overflow-hidden ring-4 ring-accent-tertiary/20 group-hover:ring-accent-tertiary/40 transition-all duration-300">
            <div class="w-full h-full bg-[url('https://picsum.photos/seed/professional-african-male-research-assistant/200/200.jpg')] bg-cover bg-center"></div>
          </div>
          <h4 class="font-semibold text-ink-900">Patrick Nding'uri</h4>
          <p class="text-sm text-ink-600">Research Assistant</p>
        </div>

        <!-- Harrison Waweru -->
        <div class="text-center group">
          <div class="w-24 h-24 rounded-full mx-auto mb-3 overflow-hidden ring-4 ring-accent-quat/20 group-hover:ring-accent-quat/40 transition-all duration-300">
            <div class="w-full h-full bg-[url('https://picsum.photos/seed/professional-african-male-data-scientist/200/200.jpg')] bg-cover bg-center"></div>
          </div>
          <h4 class="font-semibold text-ink-900">Harrison Waweru</h4>
          <p class="text-sm text-ink-600">Data Scientist</p>
        </div>

        <!-- Mark Makau -->
        <div class="text-center group">
          <div class="w-24 h-24 rounded-full mx-auto mb-3 overflow-hidden ring-4 ring-accent-violet/20 group-hover:ring-accent-violet/40 transition-all duration-300">
            <div class="w-full h-full bg-[url('https://picsum.photos/seed/professional-african-male-lab-researcher/200/200.jpg')] bg-cover bg-center"></div>
          </div>
          <h4 class="font-semibold text-ink-900">Mark Makau</h4>
          <p class="text-sm text-ink-600">Lab Technician</p>
        </div>

        <!-- Maurine Mutua -->
        <div class="text-center group">
          <div class="w-24 h-24 rounded-full mx-auto mb-3 overflow-hidden ring-4 ring-accent-coral/20 group-hover:ring-accent-coral/40 transition-all duration-300">
            <div class="w-full h-full bg-[url('https://picsum.photos/seed/professional-african-female-research-scientist/200/200.jpg')] bg-cover bg-center"></div>
          </div>
          <h4 class="font-semibold text-ink-900">Maurine Mutua</h4>
          <p class="text-sm text-ink-600">Research Officer</p>
        </div>

        <!-- Virginia Wambui -->
        <div class="text-center group">
          <div class="w-24 h-24 rounded-full mx-auto mb-3 overflow-hidden ring-4 ring-accent-teal/20 group-hover:ring-accent-teal/40 transition-all duration-300">
            <div class="w-full h-full bg-[url('https://picsum.photos/seed/professional-african-female-administrator/200/200.jpg')] bg-cover bg-center"></div>
          </div>
          <h4 class="font-semibold text-ink-900">Virginia Wambui</h4>
          <p class="text-sm text-ink-600">Lab Administrator</p>
        </div>

        <!-- Ibrahim Ndirangu -->
        <div class="text-center group">
          <div class="w-24 h-24 rounded-full mx-auto mb-3 overflow-hidden ring-4 ring-accent-gold/20 group-hover:ring-accent-gold/40 transition-all duration-300">
            <div class="w-full h-full bg-[url('https://picsum.photos/seed/professional-african-male-field-researcher/200/200.jpg')] bg-cover bg-center"></div>
          </div>
          <h4 class="font-semibold text-ink-900">Ibrahim Ndirangu</h4>
          <p class="text-sm text-ink-600">Field Researcher</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Join Our Team -->
  <section class="py-20 bg-gradient-to-r from-accent-primary to-accent-secondary">
    <div class="container-prose text-center text-white">
      <h2 class="text-4xl font-bold mb-6">Join Our Research Team</h2>
      <p class="text-xl mb-8 max-w-3xl mx-auto">
        We are always looking for passionate researchers and students to join our mission 
        to transform maternal health outcomes across Africa.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <button class="px-8 py-4 bg-gradient-to-r from-accent-primary to-accent-secondary text-white font-bold rounded-xl hover:from-accent-secondary hover:to-accent-tertiary transition-all duration-300 transform hover:scale-105 shadow-lg">
          View Open Positions
        </button>
        <button class="px-8 py-4 bg-transparent border-2 border-accent-tertiary text-accent-tertiary font-bold rounded-xl hover:bg-accent-tertiary hover:text-white transition-all duration-200">
          Collaborate With Us
        </button>
      </div>
    </div>
  </section>
</BaseLayout>
