---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Careers — MKU Centre for Placenta Research"
  description="Join our team and help transform maternal health outcomes across Africa through innovative research and healthcare solutions."
  audience="student"
>
  <!-- Hero Section -->
  <section class="relative py-20 bg-gradient-to-br from-accent-primary to-accent-secondary overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-[url('https://picsum.photos/seed/careers-research-jobs-opportunities-professional-workplace-laboratory/1920/1080.jpg')] bg-cover bg-center opacity-20"></div>
      <div class="absolute inset-0 bg-black/40"></div>
    </div>
    
    <div class="container-prose relative z-10 text-white">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center px-6 py-3 bg-white/20 backdrop-blur-md text-white text-sm font-semibold rounded-full mb-8 border border-white/30">
          💼 Career Opportunities
        </div>
        <h1 class="text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Join Our 
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-accent-secondary">
            Research Team
          </span>
        </h1>
        <p class="text-xl lg:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed">
          Be part of Africa's first dedicated placental research centre and help transform 
          maternal health outcomes through groundbreaking research and innovation.
        </p>
      </div>
    </div>
  </section>

  <!-- Current Openings -->
  <section class="py-20 bg-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Current Openings</h2>
        <p class="text-xl text-ink-600">Join our passionate team of researchers and healthcare professionals</p>
      </div>

      <div class="space-y-8">
        <!-- Position 1 -->
        <article class="bg-gradient-to-br from-accent-primary/5 to-accent-secondary/5 rounded-3xl p-8 border border-accent-primary/20 hover:shadow-2xl transition-all duration-300">
          <div class="flex flex-col lg:flex-row gap-8">
            <div class="lg:w-1/4">
              <div class="bg-gradient-to-br from-accent-primary to-accent-secondary rounded-2xl p-6 text-white text-center">
                <div class="text-4xl font-bold mb-2">Postdoc</div>
                <div class="text-sm opacity-90">Full-time</div>
              </div>
            </div>
            
            <div class="lg:w-3/4">
              <h3 class="text-2xl font-bold text-ink-900 mb-4">
                Postdoctoral Research Fellow - Placental Malaria
              </h3>
              <div class="flex flex-wrap gap-3 mb-4">
                <span class="px-3 py-1 bg-accent-primary/10 text-accent-primary rounded-full text-sm font-semibold">
                  🔬 Research
                </span>
                <span class="px-3 py-1 bg-accent-secondary/10 text-accent-secondary rounded-full text-sm font-semibold">
                  🦟 Malaria
                </span>
                <span class="px-3 py-1 bg-accent-tertiary/10 text-accent-tertiary rounded-full text-sm font-semibold">
                  🧬 Molecular Biology
                </span>
              </div>
              <p class="text-lg text-ink-700 mb-6 leading-relaxed">
                We are seeking a highly motivated postdoctoral researcher to join our placental malaria team. 
                The successful candidate will work on understanding the molecular mechanisms of placental malaria 
                and developing novel therapeutic approaches.
              </p>
              <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between">
                <div class="text-ink-600">
                  <div class="font-semibold mb-1">Requirements:</div>
                  <div class="text-sm">PhD in Molecular Biology, Immunology, or related field</div>
                </div>
                <button class="px-6 py-3 bg-gradient-to-r from-accent-primary to-accent-secondary text-white font-bold rounded-xl hover:from-accent-secondary hover:to-accent-tertiary transition-all duration-300 transform hover:scale-105 shadow-lg">
                  Apply Now →
                </button>
              </div>
            </div>
          </div>
        </article>

        <!-- Position 2 -->
        <article class="bg-gradient-to-br from-accent-secondary/5 to-accent-tertiary/5 rounded-3xl p-8 border border-accent-secondary/20 hover:shadow-2xl transition-all duration-300">
          <div class="flex flex-col lg:flex-row gap-8">
            <div class="lg:w-1/4">
              <div class="bg-gradient-to-br from-accent-secondary to-accent-tertiary rounded-2xl p-6 text-white text-center">
                <div class="text-4xl font-bold mb-2">PhD</div>
                <div class="text-sm opacity-90">3 Years</div>
              </div>
            </div>
            
            <div class="lg:w-3/4">
              <h3 class="text-2xl font-bold text-ink-900 mb-4">
                PhD Student - Single Cell Atlas of African Placenta
              </h3>
              <div class="flex flex-wrap gap-3 mb-4">
                <span class="px-3 py-1 bg-accent-secondary/10 text-accent-secondary rounded-full text-sm font-semibold">
                  🧬 Single Cell
                </span>
                <span class="px-3 py-1 bg-accent-tertiary/10 text-accent-tertiary rounded-full text-sm font-semibold">
                  📊 Bioinformatics
                </span>
                <span class="px-3 py-1 bg-accent-quat/10 text-accent-quat rounded-full text-sm font-semibold">
                  🌍 Africa
                </span>
              </div>
              <p class="text-lg text-ink-700 mb-6 leading-relaxed">
                Join our groundbreaking project to create the first comprehensive single-cell atlas 
                of the African placenta. This PhD opportunity combines cutting-edge single-cell technologies 
                with computational analysis to understand placental development and disease.
              </p>
              <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between">
                <div class="text-ink-600">
                  <div class="font-semibold mb-1">Requirements:</div>
                  <div class="text-sm">Master's degree in Life Sciences, Computer Science, or related field</div>
                </div>
                <button class="px-6 py-3 bg-gradient-to-r from-accent-secondary to-accent-tertiary text-white font-bold rounded-xl hover:from-accent-tertiary hover:to-accent-quat transition-all duration-300 transform hover:scale-105 shadow-lg">
                  Apply Now →
                </button>
              </div>
            </div>
          </div>
        </article>

        <!-- Position 3 -->
        <article class="bg-gradient-to-br from-accent-tertiary/5 to-accent-quat/5 rounded-3xl p-8 border border-accent-tertiary/20 hover:shadow-2xl transition-all duration-300">
          <div class="flex flex-col lg:flex-row gap-8">
            <div class="lg:w-1/4">
              <div class="bg-gradient-to-br from-accent-tertiary to-accent-quat rounded-2xl p-6 text-white text-center">
                <div class="text-4xl font-bold mb-2">Lab Tech</div>
                <div class="text-sm opacity-90">Full-time</div>
              </div>
            </div>
            
            <div class="lg:w-3/4">
              <h3 class="text-2xl font-bold text-ink-900 mb-4">
                Laboratory Technician - Diagnostic Development
              </h3>
              <div class="flex flex-wrap gap-3 mb-4">
                <span class="px-3 py-1 bg-accent-tertiary/10 text-accent-tertiary rounded-full text-sm font-semibold">
                  🩺 Diagnostics
                </span>
                <span class="px-3 py-1 bg-accent-quat/10 text-accent-quat rounded-full text-sm font-semibold">
                  🔬 Laboratory
                </span>
                <span class="px-3 py-1 bg-accent-violet/10 text-accent-violet rounded-full text-sm font-semibold">
                  💉 Point-of-Care
                </span>
              </div>
              <p class="text-lg text-ink-700 mb-6 leading-relaxed">
                We are looking for an experienced laboratory technician to support our diagnostic 
                development team. The role involves testing and validating point-of-care diagnostic 
                devices for congenital syphilis and other maternal health conditions.
              </p>
              <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between">
                <div class="text-ink-600">
                  <div class="font-semibold mb-1">Requirements:</div>
                  <div class="text-sm">Bachelor's degree in Medical Laboratory Science or related field</div>
                </div>
                <button class="px-6 py-3 bg-gradient-to-r from-accent-tertiary to-accent-quat text-white font-bold rounded-xl hover:from-accent-quat hover:to-accent-violet transition-all duration-300 transform hover:scale-105 shadow-lg">
                  Apply Now →
                </button>
              </div>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Why Join Us -->
  <section class="py-20 bg-gradient-to-b from-ink-50 to-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Why Join MKU CPR?</h2>
        <p class="text-xl text-ink-600">Be part of something transformative</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-20 h-20 bg-gradient-to-br from-accent-primary to-accent-secondary rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4">
            🌍
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-3">Global Impact</h3>
          <p class="text-ink-700 leading-relaxed">
            Work on research that directly impacts maternal health outcomes across Africa and globally.
          </p>
        </div>
        
        <div class="text-center">
          <div class="w-20 h-20 bg-gradient-to-br from-accent-secondary to-accent-tertiary rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4">
            🔬
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-3">Cutting-Edge Research</h3>
          <p class="text-ink-700 leading-relaxed">
            Access state-of-the-art facilities and work with the latest technologies in placental research.
          </p>
        </div>
        
        <div class="text-center">
          <div class="w-20 h-20 bg-gradient-to-br from-accent-tertiary to-accent-quat rounded-2xl flex items-center justify-center text-white text-3xl font-bold mx-auto mb-4">
            🎓
          </div>
          <h3 class="text-xl font-bold text-ink-900 mb-3">Professional Growth</h3>
          <p class="text-ink-700 leading-relaxed">
            Continuous learning opportunities, mentorship, and career development in a supportive environment.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Application Process -->
  <section class="py-20 bg-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Application Process</h2>
        <p class="text-xl text-ink-600">Simple and straightforward</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-gradient-to-br from-accent-primary to-accent-secondary rounded-full flex items-center justify-center text-white text-2xl font-bold mx-auto mb-4">
            1
          </div>
          <h3 class="text-lg font-bold text-ink-900 mb-2">Submit Application</h3>
          <p class="text-ink-700 text-sm">Send your CV and cover letter to careers@mku-cpr.org</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-gradient-to-br from-accent-secondary to-accent-tertiary rounded-full flex items-center justify-center text-white text-2xl font-bold mx-auto mb-4">
            2
          </div>
          <h3 class="text-lg font-bold text-ink-900 mb-2">Initial Review</h3>
          <p class="text-ink-700 text-sm">Our team reviews your application within 2 weeks</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-gradient-to-br from-accent-tertiary to-accent-quat rounded-full flex items-center justify-center text-white text-2xl font-bold mx-auto mb-4">
            3
          </div>
          <h3 class="text-lg font-bold text-ink-900 mb-2">Interview</h3>
          <p class="text-ink-700 text-sm">Meet with our team and discuss your research interests</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-gradient-to-br from-accent-quat to-accent-violet rounded-full flex items-center justify-center text-white text-2xl font-bold mx-auto mb-4">
            4
          </div>
          <h3 class="text-lg font-bold text-ink-900 mb-2">Join Team</h3>
          <p class="text-ink-700 text-sm">Welcome to Africa's premier placental research centre!</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-20 bg-gradient-to-r from-accent-primary to-accent-secondary">
    <div class="container-prose text-center text-white">
      <h2 class="text-4xl font-bold mb-6">Ready to Make a Difference?</h2>
      <p class="text-xl mb-8 max-w-3xl mx-auto">
        Join our mission to transform maternal health outcomes across Africa through innovative research 
        and dedicated healthcare solutions.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <button class="px-8 py-4 bg-gradient-to-r from-accent-violet to-accent-coral text-white font-bold rounded-xl hover:from-accent-coral hover:to-accent-primary transition-all duration-300 transform hover:scale-105 shadow-lg">
          View All Positions
        </button>
        <button class="px-8 py-4 bg-transparent border-2 border-accent-tertiary text-accent-tertiary font-bold rounded-xl hover:bg-accent-tertiary hover:text-white transition-all duration-200">
          Send General Inquiry
        </button>
      </div>
    </div>
  </section>
</BaseLayout>
