---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Research — MKU Centre for Placenta Research"
  description="Explore our groundbreaking research in malaria, maternal health, point-of-care diagnostics, and genomic surveillance."
  audience="scientific"
>
  <!-- Hero Section -->
  <section class="relative py-20 bg-gradient-to-br from-accent-primary to-accent-secondary overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-[url('https://picsum.photos/seed/medical-research-laboratory-scientists-working/1920/1080.jpg')] bg-cover bg-center opacity-20"></div>
      <div class="absolute inset-0 bg-black/40"></div>
    </div>
    
    <div class="container-prose relative z-10 text-white">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center px-6 py-3 bg-white/20 backdrop-blur-md text-white text-sm font-semibold rounded-full mb-8 border border-white/30">
          🔬 Cutting-Edge Research
        </div>
        <h1 class="text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Transforming 
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-accent-secondary">
            Maternal Health
          </span>
          Through Innovation
        </h1>
        <p class="text-xl lg:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed">
          Harnessing state-of-the-art molecular biology techniques to understand disease transmission, 
          develop point-of-care diagnostics, and improve maternal and newborn health outcomes.
        </p>
      </div>
    </div>
  </section>

  <!-- Research Areas -->
  <section class="py-20 bg-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Our Research Focus Areas</h2>
        <p class="text-xl text-ink-600 max-w-3xl mx-auto">
          We tackle the most critical challenges in maternal health through innovative research approaches
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Malaria Research -->
        <div class="group relative bg-gradient-to-br from-accent-primary/5 to-accent-primary/10 rounded-3xl p-8 border border-accent-primary/20 hover:shadow-2xl transition-all duration-300">
          <div class="absolute top-6 right-6 w-20 h-20 bg-accent-primary rounded-2xl flex items-center justify-center text-white text-2xl font-bold">
            🦠
          </div>
          
          <div class="mb-6">
            <div class="w-full h-48 bg-gradient-to-br from-accent-primary/20 to-accent-secondary/20 rounded-2xl mb-6 overflow-hidden">
              <div class="w-full h-full bg-[url('https://picsum.photos/seed/malaria-research-microscope-laboratory/600/300.jpg')] bg-cover bg-center"></div>
            </div>
            
            <h3 class="text-2xl font-bold text-ink-900 mb-4">Malaria Research & Genomic Surveillance</h3>
            <p class="text-ink-600 leading-relaxed mb-6">
              Harnessing state-of-the-art molecular biology techniques to understand disease transmission dynamics and pathogenesis. 
              We employ nucleic acid amplification tests, next-generation sequencing, and bioinformatics tools to characterize 
              Plasmodium genetic diversity and track drug resistance markers.
            </p>
          </div>
          
          <div class="space-y-3">
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-accent-primary rounded-full"></div>
              <span class="text-ink-700 font-medium">Next-generation sequencing</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-accent-primary rounded-full"></div>
              <span class="text-ink-700 font-medium">Drug resistance profiling</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-accent-primary rounded-full"></div>
              <span class="text-ink-700 font-medium">Transmission hotspot mapping</span>
            </div>
          </div>
          
          <button class="mt-6 w-full py-3 bg-accent-primary text-white font-semibold rounded-xl hover:bg-accent-secondary transition-colors duration-200">
            Explore Malaria Research →
          </button>
        </div>

        <!-- Maternal & Newborn Health -->
        <div class="group relative bg-gradient-to-br from-accent-secondary/5 to-accent-secondary/10 rounded-3xl p-8 border border-accent-secondary/20 hover:shadow-2xl transition-all duration-300">
          <div class="absolute top-6 right-6 w-20 h-20 bg-accent-secondary rounded-2xl flex items-center justify-center text-white text-2xl font-bold">
            🤱
          </div>
          
          <div class="mb-6">
            <div class="w-full h-48 bg-gradient-to-br from-accent-secondary/20 to-accent-tertiary/20 rounded-2xl mb-6 overflow-hidden">
              <div class="w-full h-full bg-[url('https://picsum.photos/seed/maternal-health-placenta-research/600/300.jpg')] bg-cover bg-center"></div>
            </div>
            
            <h3 class="text-2xl font-bold text-ink-900 mb-4">Maternal & Newborn Health: Placental Malaria</h3>
            <p class="text-ink-600 leading-relaxed mb-6">
              Placental malaria remains a significant challenge in maternal and newborn health. Through detailed 
              histopathological analyses and biomarker discovery, we unravel the molecular mechanisms that underlie 
              the disruption of placental function during malaria infection.
            </p>
          </div>
          
          <div class="space-y-3">
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-accent-secondary rounded-full"></div>
              <span class="text-ink-700 font-medium">Histopathological analysis</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-accent-secondary rounded-full"></div>
              <span class="text-ink-700 font-medium">Biomarker discovery</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-accent-secondary rounded-full"></div>
              <span class="text-ink-700 font-medium">Early diagnostic tools</span>
            </div>
          </div>
          
          <button class="mt-6 w-full py-3 bg-accent-secondary text-white font-semibold rounded-xl hover:bg-accent-tertiary transition-colors duration-200">
            Explore Maternal Health →
          </button>
        </div>

        <!-- Point-of-Care Diagnostics -->
        <div class="group relative bg-gradient-to-br from-accent-tertiary/5 to-accent-tertiary/10 rounded-3xl p-8 border border-accent-tertiary/20 hover:shadow-2xl transition-all duration-300">
          <div class="absolute top-6 right-6 w-20 h-20 bg-accent-tertiary rounded-2xl flex items-center justify-center text-white text-2xl font-bold">
            🧪
          </div>
          
          <div class="mb-6">
            <div class="w-full h-48 bg-gradient-to-br from-accent-tertiary/20 to-accent-quat/20 rounded-2xl mb-6 overflow-hidden">
              <div class="w-full h-full bg-[url('https://picsum.photos/seed/point-of-care-diagnostic-device-medical/600/300.jpg')] bg-cover bg-center"></div>
            </div>
            
            <h3 class="text-2xl font-bold text-ink-900 mb-4">Point-of-Care Diagnostics Development</h3>
            <p class="text-ink-600 leading-relaxed mb-6">
              We develop rapid, reliable diagnostic tests for use directly at point-of-care in resource-limited settings. 
              By integrating advanced microfluidic platforms with immunochromatographic techniques, we create tools 
              with over 95% accuracy even in low parasitemia cases.
            </p>
          </div>
          
          <div class="space-y-3">
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-accent-tertiary rounded-full"></div>
              <span class="text-ink-700 font-medium">CRISPR-based assays</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-accent-tertiary rounded-full"></div>
              <span class="text-ink-700 font-medium">Lab-on-a-chip platforms</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-accent-tertiary rounded-full"></div>
              <span class="text-ink-700 font-medium">Microfluidic integration</span>
            </div>
          </div>
          
          <button class="mt-6 w-full py-3 bg-accent-tertiary text-white font-semibold rounded-xl hover:bg-accent-quat transition-colors duration-200">
            Explore Diagnostics →
          </button>
        </div>

        <!-- Clinical Trials -->
        <div class="group relative bg-gradient-to-br from-accent-quat/5 to-accent-quat/10 rounded-3xl p-8 border border-accent-quat/20 hover:shadow-2xl transition-all duration-300">
          <div class="absolute top-6 right-6 w-20 h-20 bg-accent-quat rounded-2xl flex items-center justify-center text-white text-2xl font-bold">
            🏥
          </div>
          
          <div class="mb-6">
            <div class="w-full h-48 bg-gradient-to-br from-accent-quat/20 to-accent-violet/20 rounded-2xl mb-6 overflow-hidden">
              <div class="w-full h-full bg-[url('https://picsum.photos/seed/clinical-trials-research-hospital/600/300.jpg')] bg-cover bg-center"></div>
            </div>
            
            <h3 class="text-2xl font-bold text-ink-900 mb-4">Clinical Trials & Implementation Science</h3>
            <p class="text-ink-600 leading-relaxed mb-6">
              Bridging the gap between laboratory innovation and real-world impact through rigorous clinical trials. 
              We evaluate diagnostic tools in diverse healthcare settings, assessing usability, cost-effectiveness, 
              and impact on patient outcomes.
            </p>
          </div>
          
          <div class="space-y-3">
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-accent-quat rounded-full"></div>
              <span class="text-ink-700 font-medium">Multi-center trials</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-accent-quat rounded-full"></div>
              <span class="text-ink-700 font-medium">Implementation science</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-accent-quat rounded-full"></div>
              <span class="text-ink-700 font-medium">Health system integration</span>
            </div>
          </div>
          
          <button class="mt-6 w-full py-3 bg-accent-quat text-white font-semibold rounded-xl hover:bg-accent-violet transition-colors duration-200">
            Explore Clinical Trials →
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-20 bg-gradient-to-r from-accent-primary to-accent-secondary">
    <div class="container-prose text-center text-white">
      <h2 class="text-4xl font-bold mb-6">Join Our Research Mission</h2>
      <p class="text-xl mb-8 max-w-3xl mx-auto">
        Collaborate with us to transform maternal health outcomes across Africa through innovative research and cutting-edge diagnostics.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <button class="px-8 py-4 bg-gradient-to-r from-accent-primary to-accent-secondary text-white font-bold rounded-xl hover:from-accent-secondary hover:to-accent-tertiary transition-all duration-300 transform hover:scale-105 shadow-lg">
          Partner With Us
        </button>
        <button class="px-8 py-4 bg-transparent border-2 border-accent-tertiary text-accent-tertiary font-bold rounded-xl hover:bg-accent-tertiary hover:text-white transition-all duration-200">
          View Publications
        </button>
      </div>
    </div>
  </section>
</BaseLayout>
