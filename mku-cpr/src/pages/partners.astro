---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Partners — MKU Centre for Placenta Research"
  description="Partner with us to transform maternal health outcomes across Africa through collaborative research, healthcare innovation, and community engagement."
  audience="funder"
>
  <!-- Hero Section -->
  <section class="relative py-20 bg-gradient-to-br from-accent-primary to-accent-secondary overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-[url('https://picsum.photos/seed/partnerships-collaboration-research-healthcare-partnerships/1920/1080.jpg')] bg-cover bg-center opacity-20"></div>
      <div class="absolute inset-0 bg-black/40"></div>
    </div>
    
    <div class="container-prose relative z-10 text-white">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center px-6 py-3 bg-white/20 backdrop-blur-md text-white text-sm font-semibold rounded-full mb-8 border border-white/30">
          🤝 Partnership Opportunities
        </div>
        <h1 class="text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Partner With Us to 
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-accent-secondary">
            Transform Lives
          </span>
        </h1>
        <p class="text-xl lg:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed">
          Join our collaborative network of research institutions, healthcare organizations, 
          and community partners working together to improve maternal health across Africa.
        </p>
      </div>
    </div>
  </section>

  <!-- Partnership Types -->
  <section class="py-20 bg-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Partnership Opportunities</h2>
        <p class="text-xl text-ink-600">Find the perfect way to collaborate with us</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Research Partnerships -->
        <article class="group bg-gradient-to-br from-accent-primary/5 to-accent-secondary/5 rounded-3xl p-8 border border-accent-primary/20 hover:shadow-2xl transition-all duration-300">
          <div class="w-16 h-16 bg-gradient-to-br from-accent-primary to-accent-secondary rounded-2xl flex items-center justify-center text-white text-2xl font-bold mb-6 group-hover:scale-110 transition-transform">
            🔬
          </div>
          <h3 class="text-2xl font-bold text-ink-900 mb-4">Research Partnerships</h3>
          <p class="text-ink-700 leading-relaxed mb-6">
            Collaborate on groundbreaking research projects in placental biology, malaria, 
            and maternal health. Share expertise, resources, and facilities.
          </p>
          <ul class="space-y-2 text-ink-600 mb-6">
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Joint research proposals
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Data sharing initiatives
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Co-supervision of students
            </li>
          </ul>
          <button class="w-full px-6 py-3 bg-gradient-to-r from-accent-primary to-accent-secondary text-white font-bold rounded-xl hover:from-accent-secondary hover:to-accent-tertiary transition-all duration-300 transform hover:scale-105 shadow-lg">
            Explore Research Partnership →
          </button>
        </article>

        <!-- Healthcare Partnerships -->
        <article class="group bg-gradient-to-br from-accent-secondary/5 to-accent-tertiary/5 rounded-3xl p-8 border border-accent-secondary/20 hover:shadow-2xl transition-all duration-300">
          <div class="w-16 h-16 bg-gradient-to-br from-accent-secondary to-accent-tertiary rounded-2xl flex items-center justify-center text-white text-2xl font-bold mb-6 group-hover:scale-110 transition-transform">
            🏥
          </div>
          <h3 class="text-2xl font-bold text-ink-900 mb-4">Healthcare Partnerships</h3>
          <p class="text-ink-700 leading-relaxed mb-6">
            Partner with healthcare facilities to implement research findings, 
            conduct clinical trials, and improve maternal healthcare delivery.
          </p>
          <ul class="space-y-2 text-ink-600 mb-6">
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Clinical trial sites
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Implementation research
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Healthcare worker training
            </li>
          </ul>
          <button class="w-full px-6 py-3 bg-gradient-to-r from-accent-secondary to-accent-tertiary text-white font-bold rounded-xl hover:from-accent-tertiary hover:to-accent-quat transition-all duration-300 transform hover:scale-105 shadow-lg">
            Explore Healthcare Partnership →
          </button>
        </article>

        <!-- Community Partnerships -->
        <article class="group bg-gradient-to-br from-accent-tertiary/5 to-accent-quat/5 rounded-3xl p-8 border border-accent-tertiary/20 hover:shadow-2xl transition-all duration-300">
          <div class="w-16 h-16 bg-gradient-to-br from-accent-tertiary to-accent-quat rounded-2xl flex items-center justify-center text-white text-2xl font-bold mb-6 group-hover:scale-110 transition-transform">
            🌍
          </div>
          <h3 class="text-2xl font-bold text-ink-900 mb-4">Community Partnerships</h3>
          <p class="text-ink-700 leading-relaxed mb-6">
            Work with community organizations to improve health education, 
            conduct outreach programs, and ensure culturally appropriate research.
          </p>
          <ul class="space-y-2 text-ink-600 mb-6">
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Community engagement
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Health education programs
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Participatory research
            </li>
          </ul>
          <button class="w-full px-6 py-3 bg-gradient-to-r from-accent-tertiary to-accent-quat text-white font-bold rounded-xl hover:from-accent-quat hover:to-accent-violet transition-all duration-300 transform hover:scale-105 shadow-lg">
            Explore Community Partnership →
          </button>
        </article>

        <!-- Industry Partnerships -->
        <article class="group bg-gradient-to-br from-accent-quat/5 to-accent-violet/5 rounded-3xl p-8 border border-accent-quat/20 hover:shadow-2xl transition-all duration-300">
          <div class="w-16 h-16 bg-gradient-to-br from-accent-quat to-accent-violet rounded-2xl flex items-center justify-center text-white text-2xl font-bold mb-6 group-hover:scale-110 transition-transform">
            💼
          </div>
          <h3 class="text-2xl font-bold text-ink-900 mb-4">Industry Partnerships</h3>
          <p class="text-ink-700 leading-relaxed mb-6">
            Collaborate with pharmaceutical and diagnostic companies to develop 
            innovative solutions for maternal health challenges.
          </p>
          <ul class="space-y-2 text-ink-600 mb-6">
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Diagnostic development
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Drug discovery research
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Technology transfer
            </li>
          </ul>
          <button class="w-full px-6 py-3 bg-gradient-to-r from-accent-quat to-accent-violet text-white font-bold rounded-xl hover:from-accent-violet hover:to-accent-coral transition-all duration-300 transform hover:scale-105 shadow-lg">
            Explore Industry Partnership →
          </button>
        </article>

        <!-- Academic Partnerships -->
        <article class="group bg-gradient-to-br from-accent-violet/5 to-accent-coral/5 rounded-3xl p-8 border border-accent-violet/20 hover:shadow-2xl transition-all duration-300">
          <div class="w-16 h-16 bg-gradient-to-br from-accent-violet to-accent-coral rounded-2xl flex items-center justify-center text-white text-2xl font-bold mb-6 group-hover:scale-110 transition-transform">
            🎓
          </div>
          <h3 class="text-2xl font-bold text-ink-900 mb-4">Academic Partnerships</h3>
          <p class="text-ink-700 leading-relaxed mb-6">
            Partner with universities and research institutions worldwide to 
            advance knowledge and build research capacity in Africa.
          </p>
          <ul class="space-y-2 text-ink-600 mb-6">
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Student exchanges
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Joint degree programs
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Faculty collaborations
            </li>
          </ul>
          <button class="w-full px-6 py-3 bg-gradient-to-r from-accent-violet to-accent-coral text-white font-bold rounded-xl hover:from-accent-coral hover:to-accent-primary transition-all duration-300 transform hover:scale-105 shadow-lg">
            Explore Academic Partnership →
          </button>
        </article>

        <!-- Funding Partnerships -->
        <article class="group bg-gradient-to-br from-accent-coral/5 to-accent-primary/5 rounded-3xl p-8 border border-accent-coral/20 hover:shadow-2xl transition-all duration-300">
          <div class="w-16 h-16 bg-gradient-to-br from-accent-coral to-accent-primary rounded-2xl flex items-center justify-center text-white text-2xl font-bold mb-6 group-hover:scale-110 transition-transform">
            💰
          </div>
          <h3 class="text-2xl font-bold text-ink-900 mb-4">Funding Partnerships</h3>
          <p class="text-ink-700 leading-relaxed mb-6">
            Support our mission through strategic funding partnerships that enable 
            sustainable research and long-term impact in maternal health.
          </p>
          <ul class="space-y-2 text-ink-600 mb-6">
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Research grants
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Infrastructure support
            </li>
            <li class="flex items-center gap-2">
              <span class="text-green-500">✓</span> Endowment opportunities
            </li>
          </ul>
          <button class="w-full px-6 py-3 bg-gradient-to-r from-accent-coral to-accent-primary text-white font-bold rounded-xl hover:from-accent-primary hover:to-accent-secondary transition-all duration-300 transform hover:scale-105 shadow-lg">
            Explore Funding Partnership →
          </button>
        </article>
      </div>
    </div>
  </section>

  <!-- Current Partners -->
  <section class="py-20 bg-gradient-to-b from-ink-50 to-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Our Current Partners</h2>
        <p class="text-xl text-ink-600">Working together to transform maternal health</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
        <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-shadow flex items-center justify-center">
          <div class="text-center">
            <div class="w-16 h-16 bg-gradient-to-br from-accent-primary to-accent-secondary rounded-xl flex items-center justify-center text-white font-bold text-xl mb-3">
              WT
            </div>
            <div class="text-sm font-semibold text-ink-900">Wellcome Trust</div>
          </div>
        </div>
        
        <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-shadow flex items-center justify-center">
          <div class="text-center">
            <div class="w-16 h-16 bg-gradient-to-br from-accent-secondary to-accent-tertiary rounded-xl flex items-center justify-center text-white font-bold text-xl mb-3">
              WHO
            </div>
            <div class="text-sm font-semibold text-ink-900">WHO</div>
          </div>
        </div>
        
        <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-shadow flex items-center justify-center">
          <div class="text-center">
            <div class="w-16 h-16 bg-gradient-to-br from-accent-tertiary to-accent-quat rounded-xl flex items-center justify-center text-white font-bold text-xl mb-3">
              CDC
            </div>
            <div class="text-sm font-semibold text-ink-900">CDC Africa</div>
          </div>
        </div>
        
        <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-shadow flex items-center justify-center">
          <div class="text-center">
            <div class="w-16 h-16 bg-gradient-to-br from-accent-quat to-accent-violet rounded-xl flex items-center justify-center text-white font-bold text-xl mb-3">
              UN
            </div>
            <div class="text-sm font-semibold text-ink-900">UNICEF</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Partnership Process -->
  <section class="py-20 bg-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Partnership Process</h2>
        <p class="text-xl text-ink-600">Simple steps to start collaborating</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-gradient-to-br from-accent-primary to-accent-secondary rounded-full flex items-center justify-center text-white text-2xl font-bold mx-auto mb-4">
            1
          </div>
          <h3 class="text-lg font-bold text-ink-900 mb-2">Initial Contact</h3>
          <p class="text-ink-700 text-sm">Reach out to discuss partnership opportunities</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-gradient-to-br from-accent-secondary to-accent-tertiary rounded-full flex items-center justify-center text-white text-2xl font-bold mx-auto mb-4">
            2
          </div>
          <h3 class="text-lg font-bold text-ink-900 mb-2">Needs Assessment</h3>
          <p class="text-ink-700 text-sm">We identify mutual goals and collaboration areas</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-gradient-to-br from-accent-tertiary to-accent-quat rounded-full flex items-center justify-center text-white text-2xl font-bold mx-auto mb-4">
            3
          </div>
          <h3 class="text-lg font-bold text-ink-900 mb-2">Agreement</h3>
          <p class="text-ink-700 text-sm">Formalize partnership with clear terms and objectives</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-gradient-to-br from-accent-quat to-accent-violet rounded-full flex items-center justify-center text-white text-2xl font-bold mx-auto mb-4">
            4
          </div>
          <h3 class="text-lg font-bold text-ink-900 mb-2">Implementation</h3>
          <p class="text-ink-700 text-sm">Begin collaborative work towards shared goals</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-20 bg-gradient-to-r from-accent-primary to-accent-secondary">
    <div class="container-prose text-center text-white">
      <h2 class="text-4xl font-bold mb-6">Ready to Partner With Us?</h2>
      <p class="text-xl mb-8 max-w-3xl mx-auto">
        Join our mission to transform maternal health outcomes across Africa through 
        meaningful partnerships and collaborative innovation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <button class="px-8 py-4 bg-gradient-to-r from-accent-violet to-accent-coral text-white font-bold rounded-xl hover:from-accent-coral hover:to-accent-primary transition-all duration-300 transform hover:scale-105 shadow-lg">
          Start Partnership Discussion
        </button>
        <button class="px-8 py-4 bg-transparent border-2 border-accent-tertiary text-accent-tertiary font-bold rounded-xl hover:bg-accent-tertiary hover:text-white transition-all duration-200">
          Download Partnership Brochure
        </button>
      </div>
    </div>
  </section>
</BaseLayout>
