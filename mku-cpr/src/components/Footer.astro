---
// Enhanced Footer with improved styling and functionality
// Per CLAUDE.md §4.4: Wellcome funder boilerplate appears in every footer.
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="relative bg-slate-900 text-white overflow-hidden" role="contentinfo">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute inset-0" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width=%2260%22 height=%2260%22 viewBox=%220 0 60 60%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cg fill=%22none%22 fill-rule=%22evenodd%22%3E%3Cg fill=%22%23ffffff%22 fill-opacity=%220.4%22%3E%3Cpath d=%22M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z%22/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"></div>
  </div>

  <!-- Top Border Accent -->
  <div class="h-1 bg-gradient-to-r from-accent-primary via-accent-secondary to-accent-tertiary"></div>

  <div class="container-prose relative z-10 py-16">
    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-12 mb-16">
      <!-- Brand Section -->
      <section aria-labelledby="footer-brand" class="lg:col-span-2">
        <div class="mb-8">
          <div class="flex items-center gap-4 mb-6">
            <div class="relative">
              <div class="w-16 h-16 bg-gradient-to-br from-accent-primary to-accent-secondary rounded-2xl flex items-center justify-center text-white font-bold text-2xl shadow-2xl transform hover:rotate-3 transition-transform duration-300">
                CP
              </div>
              <div class="absolute -top-1 -right-1 w-4 h-4 bg-accent-tertiary rounded-full animate-pulse"></div>
            </div>
            <div>
              <h2 id="footer-brand" class="text-2xl font-bold text-white mb-1">MKU CPR</h2>
              <p class="text-accent-primary font-medium">Centre for Placenta Research</p>
            </div>
          </div>
          <p class="text-slate-300 leading-relaxed mb-8">
            Pioneering placental research to transform maternal health outcomes across Africa and beyond. 
            Join us in our mission to save mothers and babies through innovative science.
          </p>
        </div>

        <!-- Social Media -->
        <div class="flex items-center gap-4">
          <span class="text-sm text-slate-400 font-medium">Connect:</span>
          <div class="flex gap-3">
            <a href="#" class="group relative w-10 h-10 bg-slate-800 rounded-xl flex items-center justify-center hover:bg-accent-primary transition-all duration-300 transform hover:scale-110" aria-label="Twitter">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="transform group-hover:rotate-12 transition-transform">
                <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"></path>
              </svg>
            </a>
            <a href="#" class="group relative w-10 h-10 bg-slate-800 rounded-xl flex items-center justify-center hover:bg-accent-secondary transition-all duration-300 transform hover:scale-110" aria-label="LinkedIn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="transform group-hover:rotate-12 transition-transform">
                <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"></path>
                <circle cx="4" cy="4" r="2"></circle>
              </svg>
            </a>
            <a href="#" class="group relative w-10 h-10 bg-slate-800 rounded-xl flex items-center justify-center hover:bg-accent-tertiary transition-all duration-300 transform hover:scale-110" aria-label="ResearchGate">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="transform group-hover:rotate-12 transition-transform">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-2-2v-6l2-2v10zm1 0V9l2 2v6l-2 2zm3 0l-2-2v-6l2-2v10z"></path>
              </svg>
            </a>
          </div>
        </div>
      </section>

      <!-- Quick Links -->
      <section aria-labelledby="footer-navigation">
        <h3 id="footer-navigation" class="text-lg font-bold text-white mb-6 flex items-center gap-2">
          <span class="w-2 h-2 bg-accent-primary rounded-full"></span>
          Navigation
        </h3>
        <ul class="space-y-3">
          <li><a href={`${base}`} class="text-slate-300 hover:text-white transition-colors duration-200 flex items-center gap-2 group">
            <span class="w-1 h-1 bg-slate-600 rounded-full group-hover:bg-accent-primary transition-colors"></span>
            Home
          </a></li>
          <li><a href={`${base}about/`} class="text-slate-300 hover:text-white transition-colors duration-200 flex items-center gap-2 group">
            <span class="w-1 h-1 bg-slate-600 rounded-full group-hover:bg-accent-primary transition-colors"></span>
            About
          </a></li>
          <li><a href={`${base}research/`} class="text-slate-300 hover:text-white transition-colors duration-200 flex items-center gap-2 group">
            <span class="w-1 h-1 bg-slate-600 rounded-full group-hover:bg-accent-primary transition-colors"></span>
            Research
          </a></li>
          <li><a href={`${base}people/`} class="text-slate-300 hover:text-white transition-colors duration-200 flex items-center gap-2 group">
            <span class="w-1 h-1 bg-slate-600 rounded-full group-hover:bg-accent-primary transition-colors"></span>
            People
          </a></li>
          <li><a href={`${base}publications/`} class="text-slate-300 hover:text-white transition-colors duration-200 flex items-center gap-2 group">
            <span class="w-1 h-1 bg-slate-600 rounded-full group-hover:bg-accent-primary transition-colors"></span>
            Publications
          </a></li>
          <li><a href={`${base}news/`} class="text-slate-300 hover:text-white transition-colors duration-200 flex items-center gap-2 group">
            <span class="w-1 h-1 bg-slate-600 rounded-full group-hover:bg-accent-primary transition-colors"></span>
            News
          </a></li>
        </ul>
      </section>

      <!-- Engage -->
      <section aria-labelledby="footer-engage">
        <h3 id="footer-engage" class="text-lg font-bold text-white mb-6 flex items-center gap-2">
          <span class="w-2 h-2 bg-accent-secondary rounded-full"></span>
          Engage
        </h3>
        <ul class="space-y-3">
          <li><a href={`${base}community/`} class="text-slate-300 hover:text-white transition-colors duration-200 flex items-center gap-2 group">
            <span class="w-1 h-1 bg-slate-600 rounded-full group-hover:bg-accent-secondary transition-colors"></span>
            Community
          </a></li>
          <li><a href={`${base}careers/`} class="text-slate-300 hover:text-white transition-colors duration-200 flex items-center gap-2 group">
            <span class="w-1 h-1 bg-slate-600 rounded-full group-hover:bg-accent-secondary transition-colors"></span>
            Careers
          </a></li>
          <li><a href={`${base}partners/`} class="text-slate-300 hover:text-white transition-colors duration-200 flex items-center gap-2 group">
            <span class="w-1 h-1 bg-slate-600 rounded-full group-hover:bg-accent-secondary transition-colors"></span>
            Partners
          </a></li>
          <li><a href={`${base}contact/`} class="text-slate-300 hover:text-white transition-colors duration-200 flex items-center gap-2 group">
            <span class="w-1 h-1 bg-slate-600 rounded-full group-hover:bg-accent-secondary transition-colors"></span>
            Contact
          </a></li>
          <li><a href={`${base}donate/`} class="text-slate-300 hover:text-white transition-colors duration-200 flex items-center gap-2 group">
            <span class="w-1 h-1 bg-slate-600 rounded-full group-hover:bg-accent-secondary transition-colors"></span>
            Donate
          </a></li>
        </ul>
      </section>

      <!-- Contact Info -->
      <section aria-labelledby="footer-contact">
        <h3 id="footer-contact" class="text-lg font-bold text-white mb-6 flex items-center gap-2">
          <span class="w-2 h-2 bg-accent-tertiary rounded-full"></span>
          Contact
        </h3>
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 bg-slate-800 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
            <div>
              <p class="text-slate-300">Mount Kenya University</p>
              <p class="text-slate-400 text-sm">Thika Road, Nairobi, Kenya</p>
            </div>
          </div>
          
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 bg-slate-800 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
              </svg>
            </div>
            <div>
              <p class="text-slate-300">+254 700 123 456</p>
              <p class="text-slate-400 text-sm">Mon-Fri 8AM-6PM</p>
            </div>
          </div>
          
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 bg-slate-800 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </div>
            <div>
              <p class="text-slate-300">info@mku-cpr.org</p>
              <p class="text-slate-400 text-sm">24/7 email support</p>
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- Newsletter Section -->
    <div class="bg-slate-800 rounded-2xl p-8 mb-16 border border-slate-700">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
        <div>
          <h3 class="text-2xl font-bold text-white mb-4 flex items-center gap-3">
            <div class="w-8 h-8 bg-gradient-to-br from-accent-primary to-accent-secondary rounded-lg flex items-center justify-center">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </div>
            Stay Connected
          </h3>
          <p class="text-slate-300 leading-relaxed">
            Get the latest research updates, breakthrough discoveries, and community news delivered to your inbox.
          </p>
        </div>
        <form class="flex flex-col sm:flex-row gap-4">
          <input 
            type="email" 
            placeholder="Enter your email address" 
            class="flex-1 px-4 py-3 bg-slate-900 border border-slate-600 rounded-xl text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-accent-primary focus:border-transparent"
            required
          >
          <button type="submit" class="px-6 py-3 bg-gradient-to-r from-accent-primary to-accent-secondary text-white rounded-xl font-bold hover:from-accent-secondary hover:to-accent-tertiary transition-all duration-300 transform hover:scale-105 shadow-lg whitespace-nowrap">
            Subscribe
          </button>
        </form>
      </div>
    </div>

    <!-- Partners & Support -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-16">
      <div class="bg-slate-800 rounded-2xl p-6 border border-slate-700">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 bg-gradient-to-br from-accent-primary to-accent-secondary rounded-xl flex items-center justify-center text-white font-bold flex-shrink-0 shadow-lg">
            WT
          </div>
          <div>
            <h4 class="text-lg font-bold text-white mb-2">Wellcome Trust Support</h4>
            <p class="text-slate-300 text-sm leading-relaxed">
              Supported by Wellcome Trust Discovery Award (2026–2031). Views expressed are those of the authors and not necessarily those of Wellcome.
            </p>
          </div>
        </div>
      </div>
      
      <div class="bg-slate-800 rounded-2xl p-6 border border-slate-700">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-12 h-12 bg-gradient-to-br from-accent-secondary to-accent-tertiary rounded-xl flex items-center justify-center text-white flex-shrink-0 shadow-lg">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
              <path d="M2 17l10 5 10-5"></path>
              <path d="M2 12l10 5 10-5"></path>
            </svg>
          </div>
          <span class="text-lg font-bold text-white">Mount Kenya University</span>
        </div>
        <p class="text-slate-300 text-sm leading-relaxed">
          Leading innovation in placental research and maternal healthcare across Africa.
        </p>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-slate-700 pt-8">
      <div class="flex flex-col lg:flex-row justify-between items-center gap-6">
        <div class="text-slate-400 text-sm">
          © {year} MKU Centre for Placenta Research. All rights reserved.
        </div>
        <div class="flex flex-wrap gap-6">
          <a href={`${base}privacy/`} class="text-slate-400 hover:text-white transition-colors duration-200 text-sm">Privacy Policy</a>
          <a href={`${base}cookie-policy/`} class="text-slate-400 hover:text-white transition-colors duration-200 text-sm">Cookie Policy</a>
          <a href={`${base}terms/`} class="text-slate-400 hover:text-white transition-colors duration-200 text-sm">Terms of Use</a>
          <a href={`${base}accessibility-statement/`} class="text-slate-400 hover:text-white transition-colors duration-200 text-sm">Accessibility</a>
        </div>
      </div>
    </div>
  </div>
</footer>
