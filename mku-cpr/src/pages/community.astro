---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Community — MKU Centre for Placenta Research"
  description="Engaging with communities, partners, and stakeholders to advance maternal health across Africa."
  audience="community"
>
  <!-- Hero Section -->
  <section class="relative py-20 bg-gradient-to-br from-accent-primary to-accent-secondary overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-[url('https://picsum.photos/seed/community-engagement-maternal-health-african-mothers-healthcare/1920/1080.jpg')] bg-cover bg-center opacity-20"></div>
      <div class="absolute inset-0 bg-black/40"></div>
    </div>
    
    <div class="container-prose relative z-10 text-white">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center px-6 py-3 bg-white/20 backdrop-blur-md text-white text-sm font-semibold rounded-full mb-8 border border-white/30">
          🤝 Community Engagement
        </div>
        <h1 class="text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          Working Together for 
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-accent-secondary">
            Healthier Mothers
          </span>
        </h1>
        <p class="text-xl lg:text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed">
          We believe that research breakthroughs are most impactful when they reach the communities 
          that need them most. Our community engagement programs connect science with real-world impact.
        </p>
      </div>
    </div>
  </section>

  <!-- Community Programs -->
  <section class="py-20 bg-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Our Community Programs</h2>
        <p class="text-xl text-ink-600">Transforming research into real-world impact</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Maternal Health Workshops -->
        <article class="group relative bg-gradient-to-br from-accent-primary/5 to-accent-secondary/5 rounded-3xl p-8 border border-accent-primary/20 hover:shadow-2xl transition-all duration-300">
          <div class="flex flex-col lg:flex-row gap-8">
            <div class="lg:w-1/3">
              <div class="w-full h-48 bg-gradient-to-br from-accent-primary/20 to-accent-secondary/20 rounded-2xl overflow-hidden">
                <div class="w-full h-full bg-[url('https://picsum.photos/seed/maternal-health-workshop-pregnant-women-education-community/400/300.jpg')] bg-cover bg-center"></div>
              </div>
              <div class="mt-4 text-center">
                <span class="inline-flex items-center px-3 py-1 bg-accent-primary text-white text-sm font-semibold rounded-full">
                  🤰 Maternal Health
                </span>
              </div>
            </div>
            
            <div class="lg:w-2/3">
              <h3 class="text-2xl font-bold text-ink-900 mb-4">
                Maternal Health Workshops
              </h3>
              <p class="text-lg text-ink-700 leading-relaxed mb-6">
                Regular workshops for pregnant women and new mothers in local communities, providing education 
                on maternal health, warning signs, and when to seek medical care.
              </p>
              
              <div class="space-y-3 mb-6">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 bg-accent-primary rounded-full flex items-center justify-center text-white text-sm font-bold">
                    ✓
                  </div>
                  <span class="text-ink-700 font-medium">Monthly sessions in 12 communities</span>
                </div>
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 bg-accent-primary rounded-full flex items-center justify-center text-white text-sm font-bold">
                    ✓
                  </div>
                  <span class="text-ink-700 font-medium">Over 2,000 women reached annually</span>
                </div>
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 bg-accent-primary rounded-full flex items-center justify-center text-white text-sm font-bold">
                    ✓
                  </div>
                  <span class="text-ink-700 font-medium">Partnership with local health centers</span>
                </div>
              </div>
              
              <button class="px-6 py-3 bg-gradient-to-r from-accent-primary to-accent-secondary text-white font-bold rounded-xl hover:from-accent-secondary hover:to-accent-tertiary transition-all duration-300 transform hover:scale-105 shadow-lg">
                Join Workshop →
              </button>
            </div>
          </div>
        </article>

        <!-- Healthcare Worker Training -->
        <article class="group relative bg-gradient-to-br from-accent-secondary/5 to-accent-tertiary/5 rounded-3xl p-8 border border-accent-secondary/20 hover:shadow-2xl transition-all duration-300">
          <div class="flex flex-col lg:flex-row gap-8">
            <div class="lg:w-1/3">
              <div class="w-full h-48 bg-gradient-to-br from-accent-secondary/20 to-accent-tertiary/20 rounded-2xl overflow-hidden">
                <div class="w-full h-full bg-[url('https://picsum.photos/seed/healthcare-worker-training-medical-staff-education-workshop/400/300.jpg')] bg-cover bg-center"></div>
              </div>
              <div class="mt-4 text-center">
                <span class="inline-flex items-center px-3 py-1 bg-accent-secondary text-white text-sm font-semibold rounded-full">
                  👩‍⚕️ Healthcare Training
                </span>
              </div>
            </div>
            
            <div class="lg:w-2/3">
              <h3 class="text-2xl font-bold text-ink-900 mb-4">
                Healthcare Worker Training
              </h3>
              <p class="text-lg text-ink-700 leading-relaxed mb-6">
                Comprehensive training programs for healthcare workers on the latest diagnostic techniques 
                and treatment protocols for placental diseases.
              </p>
              
              <div class="space-y-3 mb-6">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 bg-accent-secondary rounded-full flex items-center justify-center text-white text-sm font-bold">
                    ✓
                  </div>
                  <span class="text-ink-700 font-medium">Advanced diagnostic techniques</span>
                </div>
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 bg-accent-secondary rounded-full flex items-center justify-center text-white text-sm font-bold">
                    ✓
                  </div>
                  <span class="text-ink-700 font-medium">500+ healthcare workers trained</span>
                </div>
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 bg-accent-secondary rounded-full flex items-center justify-center text-white text-sm font-bold">
                    ✓
                  </div>
                  <span class="text-ink-700 font-medium">Certification programs available</span>
                </div>
              </div>
              
              <button class="px-6 py-3 bg-gradient-to-r from-accent-secondary to-accent-tertiary text-white font-bold rounded-xl hover:from-accent-tertiary hover:to-accent-quat transition-all duration-300 transform hover:scale-105 shadow-lg">
                Register for Training →
              </button>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Impact Stories -->
  <section class="py-20 bg-gradient-to-b from-ink-50 to-white">
    <div class="container-prose">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Impact Stories</h2>
        <p class="text-xl text-ink-600">Real lives changed through our community programs</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Story 1 -->
        <article class="group relative bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden">
          <div class="w-full h-48 bg-gradient-to-br from-accent-tertiary/20 to-accent-quat/20">
            <div class="w-full h-full bg-[url('https://picsum.photos/seed/pregnant-woman-african-maternal-health-success-story/400/300.jpg')] bg-cover bg-center"></div>
          </div>
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="inline-flex items-center px-2 py-1 bg-accent-tertiary text-white text-xs font-semibold rounded-full">
                💪 Success Story
              </span>
              <time class="text-xs text-ink-500">October 2024</time>
            </div>
            <h3 class="text-xl font-bold text-ink-900 mb-3">
              Sarah's Healthy Pregnancy Journey
            </h3>
            <p class="text-ink-600 leading-relaxed mb-4">
              "Thanks to the maternal health workshop, I recognized warning signs early and got the care I needed. 
              My baby was born healthy!"
            </p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-gradient-to-br from-accent-tertiary to-accent-quat rounded-full flex items-center justify-center text-white font-bold">
                S
              </div>
              <div>
                <p class="text-sm font-semibold text-ink-900">Sarah M.</p>
                <p class="text-xs text-ink-600">New Mother, Kitale</p>
              </div>
            </div>
          </div>
        </article>

        <!-- Story 2 -->
        <article class="group relative bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden">
          <div class="w-full h-48 bg-gradient-to-br from-accent-quat/20 to-accent-violet/20">
            <div class="w-full h-full bg-[url('https://picsum.photos/seed/healthcare-worker-nurse-medical-training-success-africa/400/300.jpg')] bg-cover bg-center"></div>
          </div>
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="inline-flex items-center px-2 py-1 bg-accent-quat text-white text-xs font-semibold rounded-full">
                🎓 Professional Growth
              </span>
              <time class="text-xs text-ink-500">September 2024</time>
            </div>
            <h3 class="text-xl font-bold text-ink-900 mb-3">
              Nurse David's Transformation
            </h3>
            <p class="text-ink-600 leading-relaxed mb-4">
              "The training program transformed how I diagnose placental conditions. I can now help more mothers 
              in my community with confidence."
            </p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-gradient-to-br from-accent-quat to-accent-violet rounded-full flex items-center justify-center text-white font-bold">
                D
              </div>
              <div>
                <p class="text-sm font-semibold text-ink-900">David K.</p>
                <p class="text-xs text-ink-600">Nurse, Eldoret</p>
              </div>
            </div>
          </div>
        </article>

        <!-- Story 3 -->
        <article class="group relative bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden">
          <div class="w-full h-48 bg-gradient-to-br from-accent-violet/20 to-accent-coral/20">
            <div class="w-full h-full bg-[url('https://picsum.photos/seed/community-health-village-outreach-rural-kenya-medical/400/300.jpg')] bg-cover bg-center"></div>
          </div>
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="inline-flex items-center px-2 py-1 bg-accent-violet text-white text-xs font-semibold rounded-full">
                🌟 Community Impact
              </span>
              <time class="text-xs text-ink-500">August 2024</time>
            </div>
            <h3 class="text-xl font-bold text-ink-900 mb-3">
              Village Health Transformation
            </h3>
            <p class="text-ink-600 leading-relaxed mb-4">
              "Our village has seen a 60% reduction in maternal complications since the CPR team started their 
              community outreach program."
            </p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-gradient-to-br from-accent-violet to-accent-coral rounded-full flex items-center justify-center text-white font-bold">
                J
              </div>
              <div>
                <p class="text-sm font-semibold text-ink-900">Joseph T.</p>
                <p class="text-xs text-ink-600">Community Leader, Baringo</p>
              </div>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Get Involved -->
  <section class="py-20 bg-gradient-to-r from-accent-primary to-accent-secondary">
    <div class="container-prose text-center text-white">
      <div class="inline-flex items-center px-6 py-3 bg-white/20 backdrop-blur-md text-white text-sm font-semibold rounded-full mb-8 border border-white/30">
        🌟 Get Involved
      </div>
      <h2 class="text-4xl font-bold mb-6">Join Our Community</h2>
      <p class="text-xl mb-8 max-w-3xl mx-auto">
        Together, we can make a difference in maternal health across Africa. 
        Find out how you can contribute to our mission.
      </p>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        <div class="bg-white/10 backdrop-blur-md rounded-2xl p-8 border border-white/20">
          <div class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center text-white text-2xl font-bold mx-auto mb-4">
            🤝
          </div>
          <h3 class="text-xl font-bold mb-3">Partner With Us</h3>
          <p class="text-white/90 mb-6">
            Collaborate on research projects, community programs, or healthcare initiatives.
          </p>
          <button class="w-full px-6 py-3 bg-gradient-to-r from-accent-primary to-accent-secondary text-white font-bold rounded-xl hover:from-accent-secondary hover:to-accent-tertiary transition-all duration-300 transform hover:scale-105 shadow-lg">
            Become Partner →
          </button>
        </div>

        <div class="bg-white/10 backdrop-blur-md rounded-2xl p-8 border border-white/20">
          <div class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center text-white text-2xl font-bold mx-auto mb-4">
            🎓
          </div>
          <h3 class="text-xl font-bold mb-3">Join Training</h3>
          <p class="text-white/90 mb-6">
            Participate in our workshops and training programs for healthcare professionals.
          </p>
          <button class="w-full px-6 py-3 bg-gradient-to-r from-accent-primary to-accent-secondary text-white font-bold rounded-xl hover:from-accent-secondary hover:to-accent-tertiary transition-all duration-300 transform hover:scale-105 shadow-lg">
            View Programs →
          </button>
        </div>

        <div class="bg-white/10 backdrop-blur-md rounded-2xl p-8 border border-white/20">
          <div class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center text-white text-2xl font-bold mx-auto mb-4">
            💬
          </div>
          <h3 class="text-xl font-bold mb-3">Share Your Story</h3>
          <p class="text-white/90 mb-6">
            Help us spread awareness by sharing your experience with maternal health.
          </p>
          <button class="w-full px-6 py-3 bg-gradient-to-r from-accent-primary to-accent-secondary text-white font-bold rounded-xl hover:from-accent-secondary hover:to-accent-tertiary transition-all duration-300 transform hover:scale-105 shadow-lg">
            Share Story →
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Statistics -->
  <section class="py-20 bg-gradient-to-b from-white to-ink-50 relative overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-0 left-0 w-96 h-96 bg-accent-primary/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-0 w-96 h-96 bg-accent-secondary/5 rounded-full blur-3xl"></div>
    </div>
    
    <div class="container-prose relative z-10">
      <div class="text-center mb-16">
        <div class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-accent-primary/10 to-accent-secondary/10 text-accent-primary text-sm font-semibold rounded-full mb-8 border border-accent-primary/20">
          📈 Impact Metrics
        </div>
        <h2 class="text-4xl lg:text-5xl font-bold text-ink-900 mb-6">Our Community Impact</h2>
        <p class="text-xl lg:text-2xl text-ink-600 max-w-3xl mx-auto">
          Numbers that show our reach and effectiveness in transforming maternal health across Africa
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Lives Impacted -->
        <div class="group relative">
          <div class="absolute inset-0 bg-gradient-to-br from-accent-primary/10 to-accent-secondary/10 rounded-3xl transform scale-95 group-hover:scale-100 transition-transform duration-300"></div>
          <div class="relative text-center p-8 bg-white rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-accent-primary/20">
            <div class="w-24 h-24 bg-gradient-to-br from-accent-primary to-accent-secondary rounded-2xl flex items-center justify-center text-white text-4xl font-bold mx-auto mb-6 group-hover:scale-110 group-hover:rotate-3 transition-all duration-300 shadow-lg">
              👥
            </div>
            <div class="relative h-16 flex items-center justify-center mb-4">
              <span class="counter text-5xl font-bold text-accent-primary" data-target="10000">0</span>
              <span class="text-5xl font-bold text-accent-primary">+</span>
            </div>
            <h3 class="text-xl font-bold text-ink-900 mb-2">Lives Impacted</h3>
            <p class="text-ink-600 text-sm leading-relaxed">
              Mothers and babies directly benefited from our programs and research
            </p>
            <div class="mt-4 pt-4 border-t border-accent-primary/10">
              <div class="flex items-center justify-center gap-2 text-accent-primary">
                <div class="w-2 h-2 bg-accent-primary rounded-full animate-pulse"></div>
                <span class="text-sm font-medium">Growing Daily</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Communities Reached -->
        <div class="group relative">
          <div class="absolute inset-0 bg-gradient-to-br from-accent-secondary/10 to-accent-tertiary/10 rounded-3xl transform scale-95 group-hover:scale-100 transition-transform duration-300"></div>
          <div class="relative text-center p-8 bg-white rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-accent-secondary/20">
            <div class="w-24 h-24 bg-gradient-to-br from-accent-secondary to-accent-tertiary rounded-2xl flex items-center justify-center text-white text-4xl font-bold mx-auto mb-6 group-hover:scale-110 group-hover:rotate-3 transition-all duration-300 shadow-lg">
              🏥
            </div>
            <div class="relative h-16 flex items-center justify-center mb-4">
              <span class="counter text-5xl font-bold text-accent-secondary" data-target="25">0</span>
            </div>
            <h3 class="text-xl font-bold text-ink-900 mb-2">Communities Reached</h3>
            <p class="text-ink-600 text-sm leading-relaxed">
              Rural and urban communities across Kenya with our outreach programs
            </p>
            <div class="mt-4 pt-4 border-t border-accent-secondary/10">
              <div class="flex items-center justify-center gap-2 text-accent-secondary">
                <div class="w-2 h-2 bg-accent-secondary rounded-full animate-pulse"></div>
                <span class="text-sm font-medium">Expanding Network</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Healthcare Workers Trained -->
        <div class="group relative">
          <div class="absolute inset-0 bg-gradient-to-br from-accent-tertiary/10 to-accent-quat/10 rounded-3xl transform scale-95 group-hover:scale-100 transition-transform duration-300"></div>
          <div class="relative text-center p-8 bg-white rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-accent-tertiary/20">
            <div class="w-24 h-24 bg-gradient-to-br from-accent-tertiary to-accent-quat rounded-2xl flex items-center justify-center text-white text-4xl font-bold mx-auto mb-6 group-hover:scale-110 group-hover:rotate-3 transition-all duration-300 shadow-lg">
              👩‍⚕️
            </div>
            <div class="relative h-16 flex items-center justify-center mb-4">
              <span class="counter text-5xl font-bold text-accent-tertiary" data-target="500">0</span>
              <span class="text-5xl font-bold text-accent-tertiary">+</span>
            </div>
            <h3 class="text-xl font-bold text-ink-900 mb-2">Healthcare Workers Trained</h3>
            <p class="text-ink-600 text-sm leading-relaxed">
              Medical professionals equipped with latest diagnostic and treatment skills
            </p>
            <div class="mt-4 pt-4 border-t border-accent-tertiary/10">
              <div class="flex items-center justify-center gap-2 text-accent-tertiary">
                <div class="w-2 h-2 bg-accent-tertiary rounded-full animate-pulse"></div>
                <span class="text-sm font-medium">Ongoing Training</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Success Rate -->
        <div class="group relative">
          <div class="absolute inset-0 bg-gradient-to-br from-accent-quat/10 to-accent-violet/10 rounded-3xl transform scale-95 group-hover:scale-100 transition-transform duration-300"></div>
          <div class="relative text-center p-8 bg-white rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-accent-quat/20">
            <div class="w-24 h-24 bg-gradient-to-br from-accent-quat to-accent-violet rounded-2xl flex items-center justify-center text-white text-4xl font-bold mx-auto mb-6 group-hover:scale-110 group-hover:rotate-3 transition-all duration-300 shadow-lg">
              📊
            </div>
            <div class="relative h-16 flex items-center justify-center mb-4">
              <span class="counter text-5xl font-bold text-accent-quat" data-target="85">0</span>
              <span class="text-5xl font-bold text-accent-quat">%</span>
            </div>
            <h3 class="text-xl font-bold text-ink-900 mb-2">Success Rate</h3>
            <p class="text-ink-600 text-sm leading-relaxed">
              Positive outcomes in maternal health interventions and early detection
            </p>
            <div class="mt-4 pt-4 border-t border-accent-quat/10">
              <div class="flex items-center justify-center gap-2 text-accent-quat">
                <div class="w-2 h-2 bg-accent-quat rounded-full animate-pulse"></div>
                <span class="text-sm font-medium">Proven Results</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Additional Impact Summary -->
      <div class="mt-16 text-center">
        <div class="inline-flex items-center px-8 py-4 bg-gradient-to-r from-accent-primary to-accent-secondary text-white rounded-full shadow-lg">
          <span class="text-2xl font-bold mr-3">🎯</span>
          <span class="text-lg font-semibold">Together, we've transformed maternal healthcare for over </span>
          <span class="counter text-2xl font-bold mx-2" data-target="10000">0</span>
          <span class="text-lg font-semibold">+ families across Kenya</span>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Counter animation script
    document.addEventListener('DOMContentLoaded', function() {
      const counters = document.querySelectorAll('.counter');
      const speed = 200; // Animation speed
      
      const animateCounters = () => {
        counters.forEach(counter => {
          const target = +counter.getAttribute('data-target');
          const count = +counter.innerText.replace(/[^0-9]/g, '');
          const increment = target / speed;
          
          if (count < target) {
            counter.innerText = Math.ceil(count + increment);
            setTimeout(() => animateCounters(), 10);
          } else {
            counter.innerText = target.toLocaleString();
          }
        });
      };
      
      // Start animation when section is in view
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            animateCounters();
            observer.unobserve(entry.target);
          }
        });
      });
      
      const statsSection = document.querySelector('.counter').closest('section');
      if (statsSection) {
        observer.observe(statsSection);
      }
    });
  </script>
</BaseLayout>
